---
// BaseLayout.astro — HTML shell for every page
// Source: 07-astro-cloudflare-stack.md §2, 01-brand-system.md §4.5
//
// Props:
//   title — Page title (required)
//   description — Meta description (required)
//   ogImage — Open Graph image path (optional)

import { brand } from '@data/brand';
import { city } from '@data/city';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = '/img/og-default.jpg' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = `${title} | ${city.name} 3PL | ${brand.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Title and meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:site_name" content={`${city.name} 3PL — ${brand.name}`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Geo meta (local SEO) -->
    <meta name="geo.region" content={`US-${city.state}`} />
    <meta name="geo.placename" content={city.name} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Font preloads — GT Alpina (display) + GT Standard Mono (body) -->
    <link rel="preload" href="/fonts/GT-Alpina-Standard-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/GT-Standard-Mono-Condensed-Medium.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Generator tag -->
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <!-- Skip to content link (WCAG 2.2 AA — 04-accessibility-wcag22aa.md) -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <slot />
  </body>
</html>
