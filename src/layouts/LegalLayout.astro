---
// LegalLayout.astro — Clean text-focused layout for legal pages
// BrandBanner + Header + readable prose content + Footer
// No hero section, no cards — just a heading and body text.

import BaseLayout from './BaseLayout.astro';
import BrandBanner from '@components/sections/BrandBanner.astro';
import Header from '@components/global/Header.astro';
import Footer from '@components/global/Footer.astro';

interface Props {
  title: string;
  description: string;
  lastUpdated: string;
}

const { title, description, lastUpdated } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="page-wrapper">
    <BrandBanner />
    <Header />

    <main id="main-content" class="legal-main">
      <article class="legal-article">
        <header class="legal-header">
          <h1 class="legal-title">{title}</h1>
          <p class="legal-updated">Last updated: {lastUpdated}</p>
        </header>

        <div class="legal-body">
          <slot />
        </div>
      </article>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }

  .legal-main {
    flex: 1;
    background: var(--color-off-white);
    padding: var(--space-6) 1.25rem var(--space-8);
  }

  @media (min-width: 900px) {
    .legal-main {
      padding: var(--space-7) var(--space-6) var(--space-9);
    }
  }

  .legal-article {
    max-width: 780px;
    margin: 0 auto;
  }

  .legal-header {
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 3px solid var(--color-black);
  }

  .legal-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-black);
    text-transform: none;
    margin: 0 0 var(--space-2) 0;
  }

  .legal-updated {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-rocket-silver);
    margin: 0;
  }

  /* Body prose — all legal content flows through here */
  .legal-body {
    font-family: var(--font-body);
    font-size: var(--fs-base);
    line-height: 1.7;
    color: var(--color-black);
  }

  .legal-body :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.65rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--color-black);
    text-transform: none;
    margin: var(--space-6) 0 var(--space-3) 0;
  }

  .legal-body :global(h3) {
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-black);
    text-transform: none;
    margin: var(--space-5) 0 var(--space-2) 0;
  }

  .legal-body :global(p) {
    margin: 0 0 var(--space-3) 0;
  }

  .legal-body :global(ul),
  .legal-body :global(ol) {
    margin: 0 0 var(--space-3) 0;
    padding-left: var(--space-5);
    list-style: disc;
  }

  .legal-body :global(ol) {
    list-style: decimal;
  }

  .legal-body :global(li) {
    margin-bottom: var(--space-2);
  }

  .legal-body :global(a) {
    color: var(--color-brick-red);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .legal-body :global(a:hover) {
    color: var(--color-black);
  }

  .legal-body :global(strong) {
    font-weight: 700;
  }
</style>
