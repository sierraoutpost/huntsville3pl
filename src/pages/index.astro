---
// Home Page — Huntsville 3PL
// This placeholder uses PageLayout to verify the base layout + styles work.
// Full homepage sections will be built in Chunk 4.

import PageLayout from '@layouts/PageLayout.astro';
import { city } from '@data/city';
import { brand } from '@data/brand';
---

<PageLayout
  title="Home"
  description={`${city.tagline} ${brand.name} — ${city.name}, Alabama. Warehousing, fulfillment, cross-docking, transloading, transportation, kitting, and returns processing.`}
>
  <section class="section accent-border-top">
    <div class="container">
      <h1>{city.name} 3PL</h1>
      <p class="text-lead">{city.tagline}</p>
      <p>Full site under construction. Coming soon.</p>
      <p>
        Call us: <a href={brand.phone.href}>{brand.phone.display}</a> |
        Email: <a href={brand.email.href}>{brand.email.display}</a>
      </p>
      <p class="text-caps">{brand.hours}</p>
    </div>
  </section>
</PageLayout>
