---
// Home Page — Huntsville 3PL
// The homepage assembles all section components in order.

import PageLayout from '@layouts/PageLayout.astro';
import Hero from '@components/sections/Hero.astro';
import WhyHuntsville from '@components/sections/WhyHuntsville.astro';
import ServicesOverview from '@components/sections/ServicesOverview.astro';
import Differentiators from '@components/sections/Differentiators.astro';
import ConnectCTA from '@components/sections/ConnectCTA.astro';
import { city } from '@data/city';
import { brand } from '@data/brand';
---

<PageLayout
  title="Home"
  description={`${city.tagline} ${brand.name} — ${city.name}, Alabama. Warehousing, fulfillment, cross-docking, transloading, transportation, kitting, and returns processing.`}
>
  <Hero />
  <WhyHuntsville />
  <ServicesOverview />
  <Differentiators />
  <ConnectCTA />
</PageLayout>
