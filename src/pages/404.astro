---
// 404 — Page not found
// Full neobrutalist treatment. Nothing symmetrical, nothing template-looking.
// Oversized type, asymmetric grid, off-kilter layout.

import BaseLayout from '@layouts/BaseLayout.astro';
import BrandBanner from '@components/sections/BrandBanner.astro';
import Header from '@components/global/Header.astro';
import Footer from '@components/global/Footer.astro';
---

<BaseLayout title="404 — Page Not Found | Huntsville 3PL" description="This page doesn't exist. Let's get you back on the dock.">
  <div class="page-wrapper">
    <BrandBanner />
    <Header />

    <main id="main-content" class="four-oh-four">
      <!-- Row 1: Massive 404 + message — asymmetric split -->
      <div class="fof-grid">
        <div class="fof-num-col">
          <span class="fof-num">4</span>
          <span class="fof-num fof-num--mid">0</span>
          <span class="fof-num">4</span>
        </div>

        <div class="fof-msg-col">
          <p class="fof-eyebrow">Lost Freight</p>
          <h1 class="fof-headline">
            This page left<br />
            the dock without<br />
            a trailer.
          </h1>
          <p class="fof-body">
            Whatever was here either moved, never existed, or got misrouted.
            It happens — even in logistics. Let's get you back on track.
          </p>

          <div class="fof-links">
            <a href="/" class="fof-link fof-link--primary">Back to Home</a>
            <a href="/services/" class="fof-link">Services</a>
            <a href="/industries/" class="fof-link">Industries</a>
            <a href="/connect/" class="fof-link">Connect</a>
          </div>
        </div>
      </div>

      <!-- Row 2: Pull-quote bar — offset left, Brick Red -->
      <div class="fof-quote-bar">
        <p class="fof-quote">"If your freight can't find the dock, the dock wasn't labeled right. That's on us."</p>
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }

  .four-oh-four {
    flex: 1;
    background: var(--color-black);
    color: var(--color-off-white);
  }

  /* =============================================================
     GRID — asymmetric two-column: huge numbers LEFT, message RIGHT
     On mobile: stacks, numbers shrink into a horizontal row.
     ============================================================= */
  .fof-grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: calc(100svh - 280px);
  }

  @media (min-width: 768px) {
    .fof-grid {
      grid-template-columns: 38% 1fr;
    }
  }

  /* --- Number column --- */
  .fof-num-col {
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    justify-content: flex-start;
    padding: var(--space-6) 1.25rem var(--space-3);
    gap: 0;
    border-bottom: 2px solid var(--color-electric-yellow);
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .fof-num-col {
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-end;
      padding: var(--space-7) 1.25rem var(--space-7) var(--space-6);
      border-bottom: none;
      border-right: 2px solid var(--color-electric-yellow);
    }
  }

  .fof-num {
    font-family: var(--font-display);
    font-size: clamp(6rem, 18vw, 14rem);
    font-weight: 700;
    line-height: 0.78;
    letter-spacing: -0.06em;
    color: var(--color-off-white);
    opacity: 0.08;
    display: block;
  }

  .fof-num--mid {
    color: var(--color-electric-yellow);
    opacity: 0.25;
  }

  @media (min-width: 768px) {
    .fof-num {
      font-size: clamp(10rem, 22vw, 18rem);
    }
  }

  /* --- Message column --- */
  .fof-msg-col {
    padding: var(--space-6) 1.25rem var(--space-8);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .fof-msg-col {
      padding: var(--space-8) var(--space-7);
      max-width: 620px;
    }
  }

  .fof-eyebrow {
    font-family: var(--font-display);
    font-size: var(--fs-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-brick-red);
    margin-bottom: var(--space-4);
  }

  .fof-headline {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--color-off-white);
    text-transform: uppercase;
    margin: 0 0 var(--space-5) 0;
  }

  .fof-body {
    font-family: var(--font-body);
    font-size: var(--fs-base);
    line-height: 1.55;
    color: var(--color-off-white);
    opacity: 0.8;
    max-width: 48ch;
    margin: 0 0 var(--space-6) 0;
    border-left: 3px solid var(--color-electric-yellow);
    padding-left: var(--space-4);
  }

  /* --- Navigation links — staggered, not aligned --- */
  .fof-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .fof-link {
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    color: var(--color-black);
    background: var(--color-off-white);
    padding: 0.5em 1em;
    border: 2px solid var(--color-off-white);
    transition: background 100ms ease, color 100ms ease;
  }

  .fof-link:hover {
    background: transparent;
    color: var(--color-off-white);
  }

  .fof-link--primary {
    background: var(--color-electric-yellow);
    border-color: var(--color-electric-yellow);
    color: var(--color-black);
  }

  .fof-link--primary:hover {
    background: transparent;
    color: var(--color-electric-yellow);
  }

  /* Stagger: offset second row of links */
  .fof-link:nth-child(3) {
    margin-left: var(--space-4);
  }

  /* =============================================================
     PULL-QUOTE BAR — offset, breaks grid alignment
     ============================================================= */
  .fof-quote-bar {
    background: var(--color-brick-red);
    padding: var(--space-5) 1.25rem;
  }

  @media (min-width: 768px) {
    .fof-quote-bar {
      padding: var(--space-5) var(--space-7);
      margin-left: 38%;
    }
  }

  .fof-quote {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.35rem);
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-off-white);
    font-style: italic;
    margin: 0;
    max-width: 50ch;
  }
</style>
