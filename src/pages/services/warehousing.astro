const capabilities = [
  {
    num: '01',
    title: 'Bulk + Racked Storage',
    desc: 'Flexible storage configurations — from pallet-rack SKUs to bulk floor stacks — designed to flex with seasonal demand and growing account volumes.',
  },
  {
    num: '02',
    title: 'Climate-Controlled Zones',
    desc: 'Dedicated temperature-managed areas for humidity-sensitive, pharmaceutical, food-grade, or electronics inventory that can\'t live on the floor next to rolling doors.',
  },
  {
    num: '03',
    title: '24/7 Operations Support',
    desc: 'Round-the-clock coverage so inbound trailers, rail transfers, and air cargo from the Port of Huntsville don\'t sit waiting for a dock assignment.',
  },
  {
    num: '04',
    title: 'Modern WMS Visibility',
    desc: 'Real-time inventory accuracy, receipt confirmations, and pick/pack status — so your team always knows what\'s on hand before a customer asks.',
  },
  {
    num: '05',
    title: 'Secured + Access-Controlled',
    desc: 'Controlled entry, surveillance systems, and chain-of-custody discipline built for defense-adjacent clients who take inventory security seriously.',
  },
  {
    num: '06',
    title: 'Multiple Loading Docks',
    desc: 'Multi-dock configuration designed for efficient inbound/outbound flow, cross-dock hand-offs, and staged loading without bottlenecks.',
  },
  {
    num: '07',
    title: 'Overflow & Short-Term Storage',
    desc: 'Flexible surge capacity for seasonal peaks, product launches, or inventory in transit between facilities. No long-term commitment required — scale up when you need space and scale back when you don\'t.',
  },
];

const stats = [
  { value: '24/7', label: 'Operations coverage — no freight sits waiting' },
  { value: '$300M+', label: 'Port of Huntsville air + rail infrastructure investment' },
  { value: '21st', label: 'U.S. ranking for international air cargo volume' },
  { value: '1-Day', label: 'Drive reach: Nashville, Atlanta, Memphis, Birmingham' },
];
---

<ServiceLayout
  title={pageTitle}
  description={pageDescription}
  serviceName="Warehousing"
  serviceSlug="warehousing"
>
  <ServicePageTemplate
    serviceIndex="01"
    serviceName="Warehousing"
    tagline="Precision storage for the Rocket City. Scaled for what ships next."
    heroImage="/images/warehouse-hero-huntsville.webp"
    heroAlt="Huntsville, Alabama warehouse — bulk and racked storage, overflow and short-term storage for aerospace, defense, and e-commerce logistics"
    leadCopy="Bulk and racked storage designed for the pace of North Alabama's aerospace, defense, manufacturing, and e-commerce operators. Our Huntsville warehouse combines climate-controlled zones, 24/7 secured access, and modern WMS visibility — so your inventory moves when you do."
    whyLabel="Why Huntsville for warehousing —"
    whyCopy="North Alabama is one of the tightest and most in-demand industrial markets in the Southeast, with Q1 2025 lease rates hitting $9.49/sf NNN and 3.7% YoY rent growth. Sitting at the convergence of I-65 and I-565, our facility puts your inventory within a one-day drive of Nashville, Atlanta, Memphis, and Birmingham — and within minutes of the Port of Huntsville's International Intermodal Center, where rail lifts grew 22.3% in 2024."
    capHeadingLine1="What we run in"
    capHeadingLine2="the Rocket City."
    capabilities={capabilities}
    stats={stats}
  />
</ServiceLayout>
