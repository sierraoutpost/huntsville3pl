---
// Warehousing service page — Huntsville 3PL
// Template for remaining 6 service pages.
// Structure: ServiceLayout → Hero split (B&W photo + copy) → Capabilities rows → Stats strip → Connect CTA
//
// Sources:
//   - city-research-brief-huntsville3pl.md §2.1–2.5, §3, §4, §7
//   - services.ts (warehousing entry)

import ServiceLayout from '@layouts/ServiceLayout.astro';
import ConnectCTA from '@components/sections/ConnectCTA.astro';
import { ctaNav } from '@data/navigation';

const service = {
  slug: 'warehousing',
  name: 'Warehousing',
  tagline: 'Precision storage for the Rocket City. Scaled for what ships next.',
};

const pageTitle = 'Warehousing in Huntsville, AL';
const pageDescription =
  'Bulk and racked storage in Huntsville, Alabama — climate-controlled, 24/7 secured, modern WMS visibility. Scaled for aerospace, defense, manufacturing, and e-commerce operators across North Alabama.';

// Capabilities — brutalist row format: number + title + description
const capabilities = [
  {
    num: '01',
    title: 'Bulk + Racked Storage',
    desc: 'Flexible storage configurations — from pallet-rack SKUs to bulk floor stacks — designed to flex with seasonal demand and growing account volumes.',
  },
  {
    num: '02',
    title: 'Climate-Controlled Zones',
    desc: 'Dedicated temperature-managed areas for humidity-sensitive, pharmaceutical, food-grade, or electronics inventory that can\'t live on the floor next to rolling doors.',
  },
  {
    num: '03',
    title: '24/7 Operations Support',
    desc: 'Round-the-clock coverage so inbound trailers, rail transfers, and air cargo from the Port of Huntsville don\'t sit waiting for a dock assignment.',
  },
  {
    num: '04',
    title: 'Modern WMS Visibility',
    desc: 'Real-time inventory accuracy, receipt confirmations, and pick/pack status — so your team always knows what\'s on hand before a customer asks.',
  },
  {
    num: '05',
    title: 'Secured + Access-Controlled',
    desc: 'Controlled entry, surveillance systems, and chain-of-custody discipline built for defense-adjacent clients who take inventory security seriously.',
  },
  {
    num: '06',
    title: 'Multiple Loading Docks',
    desc: 'Multi-dock configuration designed for efficient inbound/outbound flow, cross-dock hand-offs, and staged loading without bottlenecks.',
  },
];

// Stats — mix of service capability + Huntsville market (per city brief §2.2, §3.1)
const stats = [
  { value: '24/7', label: 'Operations coverage — no freight sits waiting' },
  { value: '$300M+', label: 'Port of Huntsville air + rail infrastructure investment' },
  { value: '21st', label: 'U.S. ranking for international air cargo volume' },
  { value: '1-Day', label: 'Drive reach: Nashville, Atlanta, Memphis, Birmingham' },
];
---

<ServiceLayout
  title={pageTitle}
  description={pageDescription}
  serviceName={service.name}
  serviceSlug={service.slug}
>
  <!-- ============================================= -->
  <!-- HERO: Split photo + content                   -->
  <!-- ============================================= -->
  <section class="service-hero" aria-labelledby="service-heading">
    <div class="hero-photo">
      <img
        src="/images/warehouse-hero-huntsville.webp"
        alt="Industrial warehouse facility in Huntsville, Alabama — bulk and racked storage for North Alabama aerospace, defense, manufacturing, and e-commerce logistics"
        width="933"
        height="1400"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </div>

    <div class="hero-content">
      <p class="hero-eyebrow">Services / 01</p>
      <h1 class="hero-title" id="service-heading">{service.name}</h1>
      <p class="hero-tagline">{service.tagline}</p>

      <div class="hero-body">
        <p class="hero-lead">
          Bulk and racked storage designed for the pace of North Alabama's aerospace,
          defense, manufacturing, and e-commerce operators. Our Huntsville warehouse
          combines climate-controlled zones, 24/7 secured access, and modern WMS
          visibility — so your inventory moves when you do.
        </p>

        <p class="hero-why-label">Why Huntsville for warehousing —</p>
        <p class="hero-why">
          North Alabama is one of the tightest and most in-demand industrial markets in
          the Southeast, with Q1 2025 lease rates hitting $9.49/sf NNN and 3.7% YoY
          rent growth. Sitting at the convergence of I-65 and I-565, our facility puts
          your inventory within a one-day drive of Nashville, Atlanta, Memphis, and
          Birmingham — and within minutes of the Port of Huntsville's International
          Intermodal Center, where rail lifts grew 22.3% in 2024.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- CAPABILITIES: Brutalist full-bleed rows       -->
  <!-- ============================================= -->
  <section class="capabilities" aria-labelledby="capabilities-heading">
    <header class="cap-header">
      <p class="cap-eyebrow">Capabilities</p>
      <h2 class="cap-heading" id="capabilities-heading">
        What we run in<br />the Rocket City.
      </h2>
    </header>

    <ol class="cap-list">
      {capabilities.map((cap) => (
        <li class="cap-row">
          <span class="cap-num">{cap.num}</span>
          <div class="cap-text">
            <h3 class="cap-title">{cap.title}</h3>
            <p class="cap-desc">{cap.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- ============================================= -->
  <!-- STATS: Full-bleed strip (4 across)            -->
  <!-- ============================================= -->
  <section class="stats-strip" aria-label="Key statistics">
    <div class="stats-row">
      {stats.map((stat) => (
        <div class="stat-cell">
          <span class="stat-value">{stat.value}</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================================= -->
  <!-- CONNECT CTA                                    -->
  <!-- ============================================= -->
  <ConnectCTA />
</ServiceLayout>

<style>
  /* =============================================================
     HERO — Split photo + content (matches reference mockup)
     B&W warehouse photo left, off-white content right.
     Full-bleed photo to left viewport edge.
     ============================================================= */
  .service-hero {
    display: flex;
    flex-direction: column;
    background: var(--color-off-white);
    /* Viewport minus BrandBanner + Header (~210px) — HARD CAP to fit above fold */
    height: calc(100svh - 210px);
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .service-hero {
      flex-direction: row;
    }
  }

  /* ---- Left: photo ---- */
  .hero-photo {
    flex: 1;
    overflow: hidden;
    position: relative;
    min-height: 320px;
    background: var(--color-black);
  }

  @media (min-width: 768px) {
    .hero-photo {
      flex: 0 0 50%;
      min-height: 0;
    }
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* ---- Right: content ---- */
  .hero-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-5) 1.25rem;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .hero-content {
      flex: 0 0 50%;
      padding: var(--space-5) var(--space-5) var(--space-5) 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-content {
      padding: var(--space-6) var(--space-6) var(--space-6) 1.25rem;
    }
  }

  .hero-eyebrow {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-brick-red);
    margin-bottom: var(--space-2);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 5.5vw, 4.5rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--color-black);
    text-transform: none;
    margin-bottom: var(--space-2);
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-black);
    margin-bottom: var(--space-4);
    max-width: 32ch;
  }

  .hero-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero-lead {
    font-size: var(--fs-base);
    line-height: 1.45;
    color: var(--color-black);
    max-width: 55ch;
    border-left: 3px solid var(--color-electric-yellow);
    padding-left: var(--space-3);
    margin: 0;
  }

  .hero-why-label {
    font-family: var(--font-display);
    font-size: var(--fs-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brick-red);
    margin: var(--space-2) 0 0 0;
  }

  .hero-why {
    font-size: var(--fs-sm);
    line-height: 1.45;
    color: var(--color-black);
    max-width: 55ch;
    margin: 0;
  }

  /* =============================================================
     CAPABILITIES — Brutalist full-bleed numbered rows
     No container. Rigid visible grid. Massive numbers that clash
     with the text. Raw black borders.
     ============================================================= */
  .capabilities {
    background: white;
    border-top: 3px solid var(--color-black);
    border-bottom: 3px solid var(--color-black);
  }

  .cap-header {
    padding: var(--space-7) 1.25rem var(--space-6);
    border-bottom: 3px solid var(--color-black);
  }

  @media (min-width: 1024px) {
    .cap-header {
      padding: var(--space-8) 1.25rem var(--space-7);
    }
  }

  .cap-eyebrow {
    font-family: var(--font-display);
    font-size: var(--fs-base);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-brick-red);
    margin-bottom: var(--space-3);
  }

  .cap-heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--color-black);
    text-transform: uppercase;
    margin: 0;
  }

  .cap-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cap-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
    padding: var(--space-5) 1.25rem;
    border-bottom: 2px solid var(--color-black);
    transition: background-color 120ms ease;
  }

  .cap-row:last-child {
    border-bottom: none;
  }

  @media (min-width: 768px) {
    .cap-row {
      grid-template-columns: clamp(8rem, 20%, 14rem) 1fr;
      gap: var(--space-6);
      align-items: baseline;
      padding: var(--space-6) 1.25rem;
    }
  }

  /* Asymmetric hover — brutalist background flash */
  .cap-row:hover {
    background: var(--color-off-white);
  }

  /* Alternating brick-red numbers for odd rows */
  .cap-row:nth-child(odd) .cap-num {
    color: var(--color-brick-red);
  }

  .cap-num {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 7vw, 6rem);
    font-weight: 700;
    line-height: 0.85;
    letter-spacing: -0.02em;
    color: var(--color-black);
  }

  .cap-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cap-title {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--color-black);
    margin: 0;
  }

  .cap-desc {
    font-size: var(--fs-base);
    line-height: 1.55;
    color: var(--color-black);
    opacity: 0.85;
    max-width: 60ch;
    margin: 0;
  }

  /* =============================================================
     STATS STRIP — Full-bleed horizontal band, 4 cells
     Black bg, yellow dividers, oversized stat values
     ============================================================= */
  .stats-strip {
    background: var(--color-black);
    color: var(--color-off-white);
    border-bottom: 3px solid var(--color-black);
  }

  .stats-row {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .stats-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .stats-row {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat-cell {
    padding: var(--space-6) 1.25rem;
    border-bottom: 2px solid var(--color-electric-yellow);
  }

  @media (min-width: 640px) {
    .stat-cell {
      border-right: 2px solid var(--color-electric-yellow);
    }

    /* Remove right border on rightmost cell in each row */
    .stat-cell:nth-child(2n) {
      border-right: none;
    }

    /* Remove bottom border on last row */
    .stat-cell:nth-last-child(-n+2) {
      border-bottom: none;
    }
  }

  @media (min-width: 1024px) {
    .stat-cell {
      border-bottom: none;
      padding: var(--space-7) 1.25rem;
    }

    .stat-cell:nth-child(2n) {
      border-right: 2px solid var(--color-electric-yellow);
    }

    .stat-cell:last-child {
      border-right: none;
    }
  }

  .stat-value {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: var(--color-electric-yellow);
    margin-bottom: var(--space-3);
  }

  .stat-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-off-white);
    opacity: 0.85;
    max-width: 28ch;
  }
</style>
