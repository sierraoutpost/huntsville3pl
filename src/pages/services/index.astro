---
// /services/ — Services overview page
// Sections, top to bottom:
//   1. Hero          — full-width warehouse photo with "Services" + down-arrow
//   2. ServiceGrid   — 7 service cards linking to /services/[slug]
//   3. ConnectCTA    — closing call to action

import AboutLayout from '@layouts/AboutLayout.astro';
import ConnectCTA from '@components/sections/ConnectCTA.astro';
import { services } from '@data/services';
import { brand } from '@data/brand';
import { city } from '@data/city';

const title = 'Our Services | Warehousing, Fulfillment & Logistics';
const description =
  'Huntsville 3PL provides warehousing, fulfillment, cross-docking, transloading, transportation, kitting, and returns processing. Full-service logistics built in the Rocket City.';

// All 7 service names for SEO alt text
const serviceNames = services.map((s) => s.title.toLowerCase()).join(', ');
---

<AboutLayout title={title} description={description}>
  <!-- =========================================================
       1) HERO — full-width warehouse photo, "Services" bottom-right
       ========================================================= -->
  <section class="svc-hero" aria-label="Services hero">
    <img
      src="/images/services-hero.webp"
      alt={`Huntsville 3PL warehouse operations floor — logistics services including ${serviceNames}`}
      class="svc-hero-img"
      width="2400"
      height="1261"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <span class="svc-hero-label">
      Services<img
        src="/images/arrow-nav-down.svg"
        alt=""
        aria-hidden="true"
        class="svc-hero-arrow"
        width="1200"
        height="1200"
      />
    </span>
  </section>

  <!-- =========================================================
       2) SERVICE GRID — 7 service cards
       ========================================================= -->
  <section class="svc-grid-section" aria-labelledby="svc-grid-heading">
    <div class="svc-grid-inner">
      <header class="svc-grid-header">
        <p class="svc-grid-eyebrow">What We Do</p>
        <h2 class="svc-grid-heading" id="svc-grid-heading">
          Seven core services.<br />
          One integrated operation.
        </h2>
        <p class="svc-grid-sub">
          Every service runs through our Huntsville facility — warehousing,
          fulfillment, cross-docking, transloading, transportation, kitting,
          and returns. No hand-offs to outside vendors. Your freight stays
          under one roof and one team.
        </p>
      </header>

      <ul class="svc-grid" role="list">
        {services.map((svc, i) => (
          <li class="svc-card">
            <a href={`/services/${svc.slug}/`} class="svc-card-link">
              <span class="svc-card-num" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="svc-card-name">{svc.title}</h3>
              <p class="svc-card-desc">{svc.shortDescription}</p>
              <span class="svc-card-arrow" aria-hidden="true">&rarr;</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- =========================================================
       3) CLOSING CTA
       ========================================================= -->
  <ConnectCTA />

  <!-- Services CollectionPage JSON-LD — tells Google this is an index
       of service pages, listing all 7 offerings. -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: `https://${city.domain}/services/`,
    mainEntity: {
      '@type': 'ItemList',
      numberOfItems: services.length,
      itemListElement: services.map((svc, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: svc.title,
        url: `https://${city.domain}/services/${svc.slug}/`,
      })),
    },
    provider: {
      '@type': 'LocalBusiness',
      name: `${city.name} 3PL`,
      parentOrganization: {
        '@type': 'Organization',
        name: brand.name,
      },
    },
  })} />
</AboutLayout>

<style>
  /* =============================================================
     1) HERO — full-width warehouse photo, above the fold
     -------------------------------------------------------------
     Landscape image (2400×1261 ≈ 1.9:1). Section fills the
     above-fold space (100svh - 200px). Image uses object-fit:cover
     to fill without distortion. "Services" label + pre-rotated
     down-arrow anchored bottom-right.
     ============================================================= */
  .svc-hero {
    position: relative;
    height: clamp(280px, calc(100svh - 200px), 900px);
    overflow: hidden;
    background: var(--color-black);
    border-bottom: 3px solid var(--color-black);
  }

  .svc-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  /* "Services" + down-arrow — bottom of hero, centered horizontally
     at roughly the 58% mark from the left (between Tyler's blue marks). */
  .svc-hero-label {
    position: absolute;
    bottom: var(--space-4);
    left: 58%;
    transform: translateX(-50%);
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 4rem);
    font-weight: 700;
    color: white;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.55), 0 1px 3px rgba(0, 0, 0, 0.4);
    pointer-events: none;
    white-space: nowrap;
  }

  @media (min-width: 900px) {
    .svc-hero-label {
      bottom: var(--space-5);
    }
  }

  /* Pre-rotated down-arrow SVG — no CSS transform needed.
     Height matches the cap height of the "S" (0.72em).
     Filter inverts the black SVG to white. */
  .svc-hero-arrow {
    display: inline-block;
    height: 0.72em;
    width: auto;
    vertical-align: baseline;
    margin-left: 0.15em;
    filter: invert(1);
    pointer-events: none;
  }

  /* =============================================================
     2) SERVICE GRID — 7 cards
     ============================================================= */
  .svc-grid-section {
    background: var(--color-black);
    color: var(--color-off-white);
    padding: var(--space-7) 1.25rem;
  }

  @media (min-width: 900px) {
    .svc-grid-section {
      padding: var(--space-8) var(--space-6);
    }
  }

  .svc-grid-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .svc-grid-header {
    margin-bottom: var(--space-6);
    max-width: 880px;
  }

  .svc-grid-eyebrow {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-electric-yellow);
    margin: 0 0 var(--space-3) 0;
  }

  .svc-grid-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: var(--color-off-white);
    text-transform: none;
    margin: 0 0 var(--space-3) 0;
  }

  .svc-grid-sub {
    font-family: var(--font-body);
    font-size: var(--fs-base);
    line-height: 1.5;
    color: var(--color-off-white);
    opacity: 0.85;
    margin: 0;
  }

  .svc-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 720px) {
    .svc-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1100px) {
    .svc-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .svc-card {
    position: relative;
    background: var(--color-off-white);
    color: var(--color-black);
    border: 3px solid var(--color-off-white);
    box-shadow: 6px 6px 0 var(--color-brick-red);
    transition: transform 80ms ease, box-shadow 80ms ease;
  }

  .svc-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 var(--color-brick-red);
  }

  .svc-card:active {
    transform: translate(3px, 3px);
    box-shadow: none;
  }

  .svc-card-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5);
    text-decoration: none;
    color: inherit;
    min-height: 200px;
  }

  .svc-card-num {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-brick-red);
  }

  .svc-card-name {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.65rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--color-black);
    text-transform: none;
    margin: 0;
  }

  .svc-card-desc {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    line-height: 1.45;
    color: var(--color-black);
    opacity: 0.8;
    margin: 0;
    flex: 1;
  }

  .svc-card-arrow {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-brick-red);
    align-self: flex-end;
  }
</style>
