---
// Footer.astro — NEOBRUTALIST site footer
// Black background, thick borders, industrial grid, yellow accents
// Non-Negotiable #24: Network lockup in footer

import { brand } from '@data/brand';
import { city } from '@data/city';
import { navigation, ctaNav, footerLinks } from '@data/navigation';
import { services } from '@data/services';

const currentYear = new Date().getFullYear();
const currentCity = city.name.toLowerCase();
---

<footer class="site-footer">
  <div class="footer-inner container">
    <!-- Row 1: Main footer content -->
    <div class="footer-grid">

      <!-- Col 1: Contact info -->
      <div class="footer-col">
        <div class="footer-lockup">
          <span class="footer-city">{city.name}<span class="footer-3pl">3PL</span></span>
          <span class="footer-brand">{brand.tagline}</span>
        </div>
        <address class="footer-address">
          <p>{city.facility.address.street}</p>
          <p>{city.facility.address.city}, {city.facility.address.state} {city.facility.address.zip}</p>
        </address>
        <div class="footer-contact">
          <p>
            <a href={brand.phone.href} class="footer-link footer-link--highlight">{brand.phone.display}</a>
          </p>
          <p>
            <a href={brand.email.href} class="footer-link">{brand.email.display}</a>
          </p>
          <p class="footer-hours">{brand.hours}</p>
        </div>
      </div>

      <!-- Col 2: Site navigation -->
      <div class="footer-col">
        <h3 class="footer-heading">Navigation</h3>
        <ul class="footer-nav-list" role="list">
          <li><a href="/" class="footer-link">Home</a></li>
          {navigation.map((item) => (
            <li><a href={item.href} class="footer-link">{item.label}</a></li>
          ))}
          <li><a href={ctaNav.href} class="footer-link">{ctaNav.label}</a></li>
        </ul>
      </div>

      <!-- Col 3: Services -->
      <div class="footer-col">
        <h3 class="footer-heading">Services</h3>
        <ul class="footer-nav-list" role="list">
          {services.map((service) => (
            <li>
              <a href={`/services/${service.slug}/`} class="footer-link">{service.title}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Network locations (Non-Negotiable #24) -->
      <div class="footer-col">
        <h3 class="footer-heading">Our Network</h3>
        <ul class="footer-nav-list" role="list">
          {brand.network.map((site) => (
            <li>
              {site.name.toLowerCase() === currentCity ? (
                <span class="footer-link footer-link--current">
                  {site.name}, {site.state} <span class="sr-only">(current site)</span>
                </span>
              ) : (
                <a href={`https://${site.domain}`} class="footer-link" rel="noopener">
                  {site.name}, {site.state}
                </a>
              )}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Row 2: Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-legal">
        &copy; {currentYear} {brand.name}. All rights reserved.
      </p>
      <ul class="footer-legal-links" role="list">
        {footerLinks.map((link) => (
          <li><a href={link.href} class="footer-link">{link.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-black);
    color: var(--color-off-white);
    margin-top: auto;
    border-top: 4px solid var(--color-electric-yellow);
  }

  .footer-inner {
    padding-block: var(--space-8);
  }

  @media (min-width: 1024px) {
    .footer-inner {
      padding-block: var(--space-9);
    }
  }

  /* ---- Footer grid ---- */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.5fr 0.8fr 1fr 1fr;
      gap: var(--space-8);
    }
  }

  /* ---- Logo lockup ---- */
  .footer-lockup {
    display: flex;
    flex-direction: column;
    margin-bottom: var(--space-5);
  }

  .footer-city {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 800;
    color: var(--color-off-white);
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .footer-3pl {
    color: var(--color-brick-red);
    margin-left: 0.15em;
  }

  .footer-brand {
    font-family: var(--font-display);
    font-size: var(--fs-xs);
    color: var(--color-rocket-silver);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 2px;
  }

  /* ---- Address ---- */
  .footer-address {
    font-style: normal;
    font-size: var(--fs-sm);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    opacity: 0.7;
  }

  .footer-address p {
    max-width: none;
    margin-bottom: 0;
  }

  /* ---- Contact links ---- */
  .footer-contact p {
    max-width: none;
    margin-bottom: var(--space-1);
  }

  .footer-hours {
    font-family: var(--font-display);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-electric-yellow);
    margin-top: var(--space-3);
  }

  /* ---- Column headings ---- */
  .footer-heading {
    font-family: var(--font-display);
    font-size: var(--fs-xs);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-electric-yellow);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 3px solid rgba(247, 244, 239, 0.15);
  }

  /* ---- Nav lists ---- */
  .footer-nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  /* ---- Links ---- */
  .footer-link {
    font-size: var(--fs-sm);
    color: var(--color-off-white);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 120ms ease, color 120ms ease;
  }

  .footer-link:hover {
    opacity: 1;
    color: var(--color-electric-yellow);
  }

  .footer-link--highlight {
    font-family: var(--font-display);
    font-weight: 800;
    opacity: 1;
    color: var(--color-off-white);
  }

  .footer-link--highlight:hover {
    color: var(--color-electric-yellow);
  }

  .footer-link--current {
    opacity: 1;
    font-weight: 800;
    color: var(--color-electric-yellow);
  }

  /* ---- Bottom bar ---- */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-8);
    padding-top: var(--space-5);
    border-top: 3px solid rgba(247, 244, 239, 0.1);
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .footer-legal {
    font-size: var(--fs-xs);
    opacity: 0.5;
    max-width: none;
  }

  .footer-legal-links {
    display: flex;
    gap: var(--space-4);
  }

  .footer-legal-links .footer-link {
    font-size: var(--fs-xs);
    opacity: 0.5;
  }

  .footer-legal-links .footer-link:hover {
    opacity: 1;
  }
</style>
