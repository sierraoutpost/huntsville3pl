---
// Header.astro — NEOBRUTALIST sticky header
// Nav order (Non-Negotiable #22): Logo → Industries → Services → City → About → Blog → Connect CTA
// No blur. No soft shadows. Thick borders. Industrial.

import { brand } from '@data/brand';
import { city } from '@data/city';
import { navigation, ctaNav } from '@data/navigation';

const currentPath = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <!-- Logo lockup — far left -->
    <a href="/" class="logo-lockup" aria-label={`${city.name} 3PL — ${brand.name} — Home`}>
      <span class="logo-city">{city.name}<span class="logo-3pl">3PL</span></span>
      <span class="logo-tagline">{brand.tagline}</span>
    </a>

    <!-- RIGHT GROUP: nav + phone + CTA all together -->
    <div class="header-right-group">
      <nav class="desktop-nav" aria-label="Main navigation">
        <ul class="nav-list" role="list">
          {navigation.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['nav-link', { 'nav-link--active': currentPath.startsWith(item.href) }]}
                aria-current={currentPath.startsWith(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="header-actions">
        <a href={brand.phone.href} class="header-phone">
          {brand.phone.display}
        </a>
        <a href={ctaNav.href} class="header-cta">
          {ctaNav.label}
        </a>
      </div>
    </div>

    <!-- Mobile menu toggle — brutalist block -->
    <button
      class="mobile-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>

  <!-- Mobile menu overlay — full black takeover -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu-inner">
      <!-- CTA first -->
      <a href={ctaNav.href} class="mobile-cta">
        {ctaNav.label}
      </a>

      <!-- Phone -->
      <a href={brand.phone.href} class="mobile-phone">
        {brand.phone.display}
      </a>

      <!-- Full nav -->
      <nav aria-label="Mobile navigation">
        <ul class="mobile-nav-list" role="list">
          {navigation.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['mobile-nav-link', { 'mobile-nav-link--active': currentPath.startsWith(item.href) }]}
                aria-current={currentPath.startsWith(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Hours -->
      <p class="mobile-hours">{brand.hours}</p>
    </div>

    <!-- Close button -->
    <button class="mobile-close" aria-label="Close menu">
      <span aria-hidden="true">&times;</span>
    </button>
  </div>
</header>

<style>
  /* ---- Header shell — solid, no blur, thick bottom border ---- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-off-white);
    border-bottom: 3px solid var(--color-black);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 76px;
    gap: var(--space-5);
    padding-inline: clamp(1rem, 3vw, 2rem);
    max-width: 1600px;
    width: 100%;
    margin-inline: auto;
  }

  @media (min-width: 1024px) {
    .header-inner {
      padding-inline: clamp(2rem, 4vw, 3.5rem);
    }
  }

  /* ---- Logo lockup — bold, industrial ---- */
  .logo-lockup {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-city {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 1.75rem);
    font-weight: 700;
    color: var(--color-black);
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .logo-3pl {
    color: var(--color-brick-red);
    margin-left: 0.15em;
  }

  .logo-tagline {
    font-family: var(--font-display);
    font-size: var(--fs-xs);
    color: var(--color-rocket-silver);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.2;
    margin-top: 2px;
  }

  /* ---- Right group: nav + phone + CTA clustered together ---- */
  .header-right-group {
    display: none;
  }

  @media (min-width: 1024px) {
    .header-right-group {
      display: flex;
      align-items: center;
      gap: var(--space-5);
    }
  }

  /* ---- Desktop nav ---- */
  .desktop-nav {
    display: block;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 700;
    color: var(--color-black);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--space-2) 0;
    border-bottom: 3px solid transparent;
    transition: border-color var(--transition-fast);
  }

  .nav-link:hover {
    border-bottom-color: var(--color-electric-yellow);
  }

  .nav-link--active {
    border-bottom-color: var(--color-brick-red);
  }

  /* ---- Header actions (inside right group) ---- */
  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .header-phone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 700;
    color: var(--color-black);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border: 3px solid var(--color-black);
    box-shadow: 3px 3px 0 var(--color-black);
    white-space: nowrap;
    transition:
      transform 80ms ease,
      box-shadow 80ms ease,
      background-color 120ms ease;
  }

  .header-phone:hover {
    background-color: var(--color-black);
    color: var(--color-off-white);
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-black);
  }

  .header-phone:active {
    transform: translate(3px, 3px);
    box-shadow: none;
  }

  /* ---- Header CTA — Brick Red, hard shadow, NO radius ---- */
  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-5);
    background-color: var(--color-brick-red);
    color: var(--color-off-white);
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: 3px solid var(--color-black);
    box-shadow: 3px 3px 0 var(--color-black);
    transition:
      transform var(--transition-brutal, 80ms ease),
      box-shadow var(--transition-brutal, 80ms ease);
    white-space: nowrap;
  }

  .header-cta:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-black);
  }

  .header-cta:active {
    transform: translate(3px, 3px);
    box-shadow: none;
  }

  /* ---- Mobile toggle — thick lines, brutalist ---- */
  .mobile-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 6px;
    width: 48px;
    height: 48px;
    background: none;
    border: 3px solid var(--color-black);
    cursor: pointer;
    padding: var(--space-2);
    transition: background-color var(--transition-fast);
  }

  .mobile-toggle:hover {
    background: var(--color-electric-yellow);
  }

  @media (min-width: 1024px) {
    .mobile-toggle {
      display: none;
    }
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 3px;
    background-color: var(--color-black);
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  .mobile-toggle[aria-expanded='true'] .hamburger-line:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }

  .mobile-toggle[aria-expanded='true'] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .mobile-toggle[aria-expanded='true'] .hamburger-line:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  /* ---- Mobile menu overlay — BLACK TAKEOVER ---- */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: var(--color-black);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 200ms ease, visibility 200ms ease;
  }

  .mobile-menu.open {
    opacity: 1;
    visibility: visible;
  }

  @media (min-width: 1024px) {
    .mobile-menu {
      display: none !important;
    }
  }

  .mobile-menu-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-7);
    text-align: center;
  }

  .mobile-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-7);
    background-color: var(--color-brick-red);
    color: var(--color-off-white);
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: 3px solid var(--color-off-white);
    box-shadow: 5px 5px 0 var(--color-electric-yellow);
  }

  .mobile-phone {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 700;
    color: var(--color-electric-yellow);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .mobile-nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .mobile-nav-link {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 700;
    color: var(--color-off-white);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    padding: var(--space-3) var(--space-5);
    min-height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 3px solid transparent;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .mobile-nav-link:hover {
    color: var(--color-electric-yellow);
    border-bottom-color: var(--color-electric-yellow);
  }

  .mobile-nav-link--active {
    color: var(--color-electric-yellow);
    border-bottom-color: var(--color-brick-red);
  }

  .mobile-hours {
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    color: var(--color-rocket-silver);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .mobile-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 3px solid var(--color-off-white);
    font-size: 1.75rem;
    color: var(--color-off-white);
    cursor: pointer;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .mobile-close:hover {
    background: var(--color-electric-yellow);
    color: var(--color-black);
    border-color: var(--color-electric-yellow);
  }
</style>

<script>
  // Mobile menu toggle
  const toggle = document.querySelector('.mobile-toggle') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu');
  const closeBtn = document.querySelector('.mobile-close') as HTMLButtonElement;

  function openMenu() {
    if (!toggle || !menu) return;
    toggle.setAttribute('aria-expanded', 'true');
    menu.setAttribute('aria-hidden', 'false');
    menu.classList.add('open');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeMenu() {
    if (!toggle || !menu) return;
    toggle.setAttribute('aria-expanded', 'false');
    menu.setAttribute('aria-hidden', 'true');
    menu.classList.remove('open');
    document.body.style.overflow = '';
    toggle.focus();
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMenu() : openMenu();
  });

  closeBtn?.addEventListener('click', closeMenu);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.classList.contains('open')) {
      closeMenu();
    }
  });

  // Close when clicking a nav link
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
