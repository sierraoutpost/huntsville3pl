---
// Header.astro — NEOBRUTALIST nav bar (Row 2 of homepage layout)
// Reference: skincare site nav strip
// Nav links left, phone button + Connect CTA right
// White background, black borders top and bottom, flush to edges

import { brand } from '@data/brand';
import { city } from '@data/city';
import { navigation, ctaNav } from '@data/navigation';

const currentPath = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <!-- Nav links — left side -->
    <nav class="desktop-nav" aria-label="Main navigation">
      <ul class="nav-list" role="list">
        {navigation.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['nav-link', { 'nav-link--active': currentPath.startsWith(item.href) }]}
              aria-current={currentPath.startsWith(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Right side: phone + Connect CTA -->
    <div class="header-actions">
      <a href={brand.phone.href} class="header-phone">
        {brand.phone.display}
      </a>
      <a href={ctaNav.href} class="header-cta">
        {ctaNav.label}
      </a>
    </div>

    <!-- Mobile menu toggle -->
    <button
      class="mobile-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>

  <!-- Mobile menu overlay -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu-inner">
      <a href={ctaNav.href} class="mobile-cta">
        {ctaNav.label}
      </a>
      <a href={brand.phone.href} class="mobile-phone">
        {brand.phone.display}
      </a>
      <nav aria-label="Mobile navigation">
        <ul class="mobile-nav-list" role="list">
          {navigation.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['mobile-nav-link', { 'mobile-nav-link--active': currentPath.startsWith(item.href) }]}
                aria-current={currentPath.startsWith(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <p class="mobile-hours">{brand.hours}</p>
    </div>
    <button class="mobile-close" aria-label="Close menu">
      <span aria-hidden="true">&times;</span>
    </button>
  </div>
</header>

<style>
  /* ---- Nav bar — white strip, black borders ---- */
  .site-header {
    background: white;
    border-top: 3px solid var(--color-black);
    border-bottom: 3px solid var(--color-black);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 52px;
    padding-inline: 1.25rem;
    width: 100%;
  }

  /* ---- Desktop nav — left side ---- */
  .desktop-nav {
    display: none;
  }

  @media (min-width: 1024px) {
    .desktop-nav {
      display: block;
    }
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: var(--fs-base);
    font-weight: 500;
    color: var(--color-black);
    text-decoration: none;
    text-transform: none;
    letter-spacing: 0.01em;
    transition: color 120ms ease;
  }

  .nav-link:hover {
    color: var(--color-brick-red);
  }

  .nav-link--active {
    color: var(--color-brick-red);
  }

  /* ---- Right side: phone + CTA ---- */
  .header-actions {
    display: none;
  }

  @media (min-width: 1024px) {
    .header-actions {
      display: flex;
      align-items: center;
      gap: 0;
    }
  }

  .header-phone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--space-5);
    height: 52px;
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--color-black);
    text-decoration: none;
    border-left: 3px solid var(--color-black);
    transition: background-color 120ms ease;
    white-space: nowrap;
  }

  .header-phone:hover {
    background-color: var(--color-off-white);
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--space-6);
    height: 52px;
    background-color: var(--color-brick-red);
    color: white;
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border-left: 3px solid var(--color-black);
    transition: background-color 120ms ease;
    white-space: nowrap;
  }

  .header-cta:hover {
    background-color: var(--color-brick-red-hover);
  }

  /* ---- Mobile toggle ---- */
  .mobile-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 6px;
    width: 48px;
    height: 48px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
  }

  @media (min-width: 1024px) {
    .mobile-toggle {
      display: none;
    }
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 3px;
    background-color: var(--color-black);
    transition: transform 150ms ease, opacity 150ms ease;
  }

  .mobile-toggle[aria-expanded='true'] .hamburger-line:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }

  .mobile-toggle[aria-expanded='true'] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .mobile-toggle[aria-expanded='true'] .hamburger-line:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  /* ---- Mobile menu overlay ---- */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: var(--color-black);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 200ms ease, visibility 200ms ease;
  }

  .mobile-menu.open {
    opacity: 1;
    visibility: visible;
  }

  @media (min-width: 1024px) {
    .mobile-menu {
      display: none !important;
    }
  }

  .mobile-menu-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-7);
    text-align: center;
  }

  .mobile-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-7);
    background-color: var(--color-brick-red);
    color: white;
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: 3px solid white;
  }

  .mobile-phone {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 700;
    color: var(--color-electric-yellow);
    text-decoration: none;
  }

  .mobile-nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .mobile-nav-link {
    font-family: var(--font-body);
    font-size: var(--fs-lg);
    font-weight: 500;
    color: white;
    text-decoration: none;
    padding: var(--space-3) var(--space-5);
    min-height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 120ms ease;
  }

  .mobile-nav-link:hover {
    color: var(--color-electric-yellow);
  }

  .mobile-nav-link--active {
    color: var(--color-electric-yellow);
  }

  .mobile-hours {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    color: var(--color-rocket-silver);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .mobile-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 3px solid white;
    font-size: 1.75rem;
    color: white;
    cursor: pointer;
    transition: background-color 120ms ease;
  }

  .mobile-close:hover {
    background: var(--color-electric-yellow);
    color: var(--color-black);
    border-color: var(--color-electric-yellow);
  }
</style>

<script>
  const toggle = document.querySelector('.mobile-toggle') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu');
  const closeBtn = document.querySelector('.mobile-close') as HTMLButtonElement;

  function openMenu() {
    if (!toggle || !menu) return;
    toggle.setAttribute('aria-expanded', 'true');
    menu.setAttribute('aria-hidden', 'false');
    menu.classList.add('open');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeMenu() {
    if (!toggle || !menu) return;
    toggle.setAttribute('aria-expanded', 'false');
    menu.setAttribute('aria-hidden', 'true');
    menu.classList.remove('open');
    document.body.style.overflow = '';
    toggle.focus();
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMenu() : openMenu();
  });

  closeBtn?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.classList.contains('open')) {
      closeMenu();
    }
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
