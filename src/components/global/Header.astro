---
// Header.astro — NEOBRUTALIST nav bar (Row 2 of site layout)
// Nav links left, phone + Connect CTA right.
// Nav items with `children` render a dropdown panel on hover/focus.
// The dropdown arrow is an inline SVG that uses `fill="currentColor"` —
// so it inherits whatever color the nav link is (including hover color).

import { brand } from '@data/brand';
import { navigation, ctaNav } from '@data/navigation';

interface Props {
  mirrored?: boolean;
}

const { mirrored = false } = Astro.props;
const currentPath = Astro.url.pathname;

// Decide whether a top-level nav item should be marked "active".
// For items with children, we treat the parent as active if the current path
// starts with the parent's href OR matches any child href.
function isActive(item: (typeof navigation)[number]) {
  if (currentPath.startsWith(item.href)) return true;
  if (item.children) {
    return item.children.some((c) => currentPath.startsWith(c.href));
  }
  return false;
}
---

<header class="site-header" id="site-header" data-mirrored={mirrored ? 'true' : undefined}>
  <div class="header-inner">
    <!-- Desktop nav — left side -->
    <nav class="desktop-nav" aria-label="Main navigation">
      <ul class="nav-list" role="list">
        {navigation.map((item) => (
          <li class:list={['nav-item', { 'nav-item--dropdown': item.children }]}>
            <a
              href={item.href}
              class:list={['nav-link', { 'nav-link--active': isActive(item) }]}
              aria-current={isActive(item) ? 'page' : undefined}
              aria-haspopup={item.children ? 'true' : undefined}
              aria-expanded={item.children ? 'false' : undefined}
            >
              <span class="nav-link-label">{item.label}</span>
              {item.children && (
                <svg
                  class="nav-arrow"
                  viewBox="0 0 1200 1200"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path
                    fill="currentColor"
                    d="m447.66 630.47v-60.938c0-3.75-1.4062-7.4062-3.8906-10.172l-137.11-152.34c-2.9062-3.2344-6.9844-5.0625-11.344-5.0625h-167.58c-8.3906 0-15.234 6.7969-15.234 15.234v60.938c0 3.75 1.4062 7.4062 3.8906 10.172l100.5 111.7-100.5 111.7c-2.5312 2.8125-3.8906 6.4219-3.8906 10.172v60.938c0 8.4375 6.8438 15.234 15.234 15.234h167.58c4.3125 0 8.4375-1.8281 11.344-5.0625l137.11-152.34c2.5312-2.8125 3.8906-6.4219 3.8906-10.172zm-304.69-158.21v-15.375l101.39 112.64-6.9375 7.6875zm133.22 107.44c5.2031-5.7656 5.2031-14.578 0-20.391l-114.23-126.94h126.56l123.37 137.11-123.37 137.11h-126.61l114.23-126.94zm12.328 187.87h-145.55v-30.469h152.34c4.3125 0 8.4375-1.8281 11.344-5.0625l110.53-122.86v15.422zm479.06-137.11v-60.938c0-3.75-1.4062-7.4062-3.8906-10.172l-137.11-152.34c-2.9062-3.2344-6.9844-5.0625-11.344-5.0625h-167.58c-8.3906 0-15.234 6.7969-15.234 15.234v60.938c0 3.75 1.4062 7.4062 3.8906 10.172l100.5 111.7-100.5 111.7c-2.5312 2.8125-3.8906 6.4219-3.8906 10.172v60.938c0 8.4375 6.8438 15.234 15.234 15.234h167.58c4.3125 0 8.4375-1.8281 11.344-5.0625l137.11-152.34c2.5312-2.8125 3.8906-6.4219 3.8906-10.172zm-304.69-158.21v-15.375l101.39 112.64-6.9375 7.6875zm133.22 107.44c5.2031-5.7656 5.2031-14.578 0-20.391l-114.23-126.94h126.56l123.37 137.11-123.37 137.11h-126.61l114.23-126.94zm12.328 187.87h-145.55v-30.469h152.34c4.3125 0 8.4375-1.8281 11.344-5.0625l110.53-122.86v15.422zm475.18-208.22-137.11-152.34c-2.9062-3.2344-6.9844-5.0625-11.344-5.0625h-167.58c-8.3906 0-15.234 6.7969-15.234 15.234v60.938c0 3.75 1.4062 7.4062 3.8906 10.172l100.5 111.7-100.5 111.7c-2.5312 2.8125-3.8906 6.4219-3.8906 10.172v60.938c0 8.4375 6.8438 15.234 15.234 15.234h167.58c4.3125 0 8.4375-1.8281 11.344-5.0625l137.11-152.34c2.5312-2.8125 3.8906-6.4219 3.8906-10.172v-60.938c0-3.75-1.4062-7.4062-3.8906-10.172zm-300.79-87.094v-15.375l101.39 112.64-6.9375 7.6875zm133.22 107.44c5.2031-5.7656 5.2031-14.578 0-20.391l-114.23-126.94h126.56l123.37 137.11-123.37 137.11h-126.61l114.23-126.94zm12.328 187.87h-145.55v-30.469h152.34c4.3125 0 8.4375-1.8281 11.344-5.0625l110.53-122.86v15.422z"
                  />
                </svg>
              )}
            </a>

            {item.children && (
              <div class="dropdown-wrapper">
                <ul class="dropdown-panel" role="list">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class:list={['dropdown-link', { 'dropdown-link--active': currentPath.startsWith(child.href) }]}
                        aria-current={currentPath.startsWith(child.href) ? 'page' : undefined}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <!-- Right side: phone + Connect CTA -->
    <div class="header-actions">
      <a href={brand.phone.href} class="header-phone">
        {brand.phone.display}
      </a>
      <a href={ctaNav.href} class="header-cta">
        {ctaNav.label}
      </a>
    </div>

    <!-- Mobile menu toggle -->
    <button
      class="mobile-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>

  <!-- Mobile menu overlay -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu-inner">
      <a href={ctaNav.href} class="mobile-cta">
        {ctaNav.label}
      </a>
      <a href={brand.phone.href} class="mobile-phone">
        {brand.phone.display}
      </a>
      <nav aria-label="Mobile navigation">
        <ul class="mobile-nav-list" role="list">
          {navigation.map((item) => (
            <li class="mobile-nav-item">
              <a
                href={item.href}
                class:list={['mobile-nav-link', { 'mobile-nav-link--active': isActive(item) }]}
                aria-current={isActive(item) ? 'page' : undefined}
              >
                {item.label}
              </a>
              {item.children && (
                <ul class="mobile-sub-list" role="list">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class:list={['mobile-sub-link', { 'mobile-sub-link--active': currentPath.startsWith(child.href) }]}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      </nav>
      <p class="mobile-hours">{brand.hours}</p>
    </div>
    <button class="mobile-close" aria-label="Close menu">
      <span aria-hidden="true">&times;</span>
    </button>
  </div>
</header>

<style>
  /* ---- Nav bar — white strip, black borders ---- */
  .site-header {
    background: white;
    border-top: 3px solid var(--color-black);
    border-bottom: 3px solid var(--color-black);
    position: relative; /* anchor for any absolutely-positioned children */
    z-index: 40;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 52px;
    padding-inline: 1.25rem;
    width: 100%;
  }

  /* ---- Desktop nav — left side ---- */
  .desktop-nav {
    display: none;
  }

  @media (min-width: 1024px) {
    .desktop-nav {
      display: block;
    }
  }

  .nav-list {
    display: flex;
    align-items: stretch;
    gap: var(--space-6);
    height: 52px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    position: relative; /* dropdown anchor */
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    height: 52px;
    font-family: var(--font-body);
    font-size: var(--fs-base);
    font-weight: 500;
    color: var(--color-black);
    text-decoration: none;
    text-transform: none;
    letter-spacing: 0.01em;
    transition: color 120ms ease;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--color-brick-red);
  }

  .nav-link--active {
    color: var(--color-brick-red);
  }

  /* ---- Dropdown arrow — inherits color via currentColor ---- */
  .nav-arrow {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    color: inherit; /* path uses fill="currentColor" */
    transform: rotate(-90deg); /* base SVG points right — rotate to point UP at rest */
    transform-origin: center;
    transition: transform 220ms ease;
  }

  /* On hover/focus of the dropdown nav item, flip arrow 180° so it points DOWN */
  .nav-item--dropdown:hover .nav-arrow,
  .nav-item--dropdown:focus-within .nav-arrow {
    transform: rotate(90deg);
  }

  /* ---- Dropdown panel ---- */
  .dropdown-wrapper {
    position: absolute;
    top: 100%; /* directly below the nav bar's bottom border */
    left: 0;
    padding-top: 0.75rem; /* invisible hover bridge */
    display: none;
    z-index: 60;
  }

  .nav-item--dropdown:hover .dropdown-wrapper,
  .nav-item--dropdown:focus-within .dropdown-wrapper {
    display: block;
  }

  .dropdown-panel {
    list-style: none;
    padding: 0;
    margin: 0;
    min-width: 280px;
    background: white;
    border: 3px solid var(--color-black);
    box-shadow: 6px 6px 0 var(--color-brick-red);
  }

  .dropdown-link {
    display: block;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--color-black);
    text-decoration: none;
    border-bottom: 2px solid var(--color-black);
    transition:
      background-color 120ms ease,
      color 120ms ease;
  }

  .dropdown-panel li:last-child .dropdown-link {
    border-bottom: none;
  }

  .dropdown-link:hover,
  .dropdown-link:focus-visible {
    background: var(--color-electric-yellow);
    color: var(--color-black);
  }

  .dropdown-link--active {
    background: var(--color-off-white);
    color: var(--color-brick-red);
  }

  /* ---- Right side: phone + CTA ---- */
  .header-actions {
    display: none;
  }

  @media (min-width: 1024px) {
    .header-actions {
      display: flex;
      align-items: center;
      gap: 0;
    }
  }

  .header-phone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--space-5);
    height: 52px;
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--color-black);
    text-decoration: none;
    border-left: 3px solid var(--color-black);
    transition: background-color 120ms ease;
    white-space: nowrap;
  }

  .header-phone:hover {
    background-color: var(--color-off-white);
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--space-6);
    height: 52px;
    background-color: var(--color-brick-red);
    color: white;
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border-left: 3px solid var(--color-black);
    transition: background-color 120ms ease;
    white-space: nowrap;
  }

  .header-cta:hover {
    background-color: var(--color-brick-red-hover);
  }

  /* ---- MIRRORED VARIANT ---- */
  /* Used on Industries pages: Connect CTA + phone on the LEFT,
     nav links on the RIGHT. BrandBanner above is unaffected. */
  .site-header[data-mirrored='true'] .header-inner {
    flex-direction: row-reverse;
  }

  .site-header[data-mirrored='true'] .header-actions {
    flex-direction: row-reverse;
  }

  .site-header[data-mirrored='true'] .header-phone {
    border-left: none;
    border-right: 3px solid var(--color-black);
  }

  .site-header[data-mirrored='true'] .header-cta {
    border-left: none;
    border-right: 3px solid var(--color-black);
  }

  /* Dropdown panel anchored to right side of its parent in mirrored mode,
     so long dropdowns don't overflow the viewport on the right. */
  .site-header[data-mirrored='true'] .dropdown-wrapper {
    left: auto;
    right: 0;
  }

  /* ---- Mobile toggle ---- */
  .mobile-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 6px;
    width: 48px;
    height: 48px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
  }

  @media (min-width: 1024px) {
    .mobile-toggle {
      display: none;
    }
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 3px;
    background-color: var(--color-black);
    transition:
      transform 150ms ease,
      opacity 150ms ease;
  }

  .mobile-toggle[aria-expanded='true'] .hamburger-line:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }

  .mobile-toggle[aria-expanded='true'] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .mobile-toggle[aria-expanded='true'] .hamburger-line:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  /* ---- Mobile menu overlay ---- */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: var(--color-black);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 200ms ease,
      visibility 200ms ease;
    overflow-y: auto;
  }

  .mobile-menu.open {
    opacity: 1;
    visibility: visible;
  }

  @media (min-width: 1024px) {
    .mobile-menu {
      display: none !important;
    }
  }

  .mobile-menu-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    text-align: center;
    padding: var(--space-7) var(--space-4);
  }

  .mobile-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-7);
    background-color: var(--color-brick-red);
    color: white;
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: 3px solid white;
  }

  .mobile-phone {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 700;
    color: var(--color-electric-yellow);
    text-decoration: none;
  }

  .mobile-nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mobile-nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .mobile-nav-link {
    font-family: var(--font-body);
    font-size: var(--fs-lg);
    font-weight: 500;
    color: white;
    text-decoration: none;
    padding: var(--space-3) var(--space-5);
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 120ms ease;
  }

  .mobile-nav-link:hover {
    color: var(--color-electric-yellow);
  }

  .mobile-nav-link--active {
    color: var(--color-electric-yellow);
  }

  .mobile-sub-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    border-left: 2px solid var(--color-electric-yellow);
    padding-left: var(--space-4);
  }

  .mobile-sub-link {
    font-family: var(--font-body);
    font-size: var(--fs-base);
    font-weight: 400;
    color: var(--color-off-white);
    opacity: 0.85;
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    display: block;
    transition: color 120ms ease, opacity 120ms ease;
  }

  .mobile-sub-link:hover {
    color: var(--color-electric-yellow);
    opacity: 1;
  }

  .mobile-sub-link--active {
    color: var(--color-electric-yellow);
    opacity: 1;
  }

  .mobile-hours {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    color: var(--color-rocket-silver);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .mobile-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 3px solid white;
    font-size: 1.75rem;
    color: white;
    cursor: pointer;
    transition: background-color 120ms ease;
  }

  .mobile-close:hover {
    background: var(--color-electric-yellow);
    color: var(--color-black);
    border-color: var(--color-electric-yellow);
  }
</style>

<script>
  const toggle = document.querySelector('.mobile-toggle') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu');
  const closeBtn = document.querySelector('.mobile-close') as HTMLButtonElement;

  function openMenu() {
    if (!toggle || !menu) return;
    toggle.setAttribute('aria-expanded', 'true');
    menu.setAttribute('aria-hidden', 'false');
    menu.classList.add('open');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeMenu() {
    if (!toggle || !menu) return;
    toggle.setAttribute('aria-expanded', 'false');
    menu.setAttribute('aria-hidden', 'true');
    menu.classList.remove('open');
    document.body.style.overflow = '';
    toggle.focus();
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMenu() : openMenu();
  });

  closeBtn?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.classList.contains('open')) {
      closeMenu();
    }
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
