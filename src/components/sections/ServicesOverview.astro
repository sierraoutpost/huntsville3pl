---
// ServicesOverview.astro — NEOBRUTALIST services section (v2)
// Asymmetric: heading on left, services stagger right
// Thick borders, hard shadows, bold type.

import { services } from '@data/services';
---

<section class="services-section section" aria-labelledby="services-heading">
  <div class="container">
    <!-- Asymmetric layout: header left, cards right -->
    <div class="services-layout">
      <div class="services-header">
        <p class="services-eyebrow">What We Do</p>
        <h2 class="services-heading" id="services-heading">
          Full-service 3PL.<br />One call to&nbsp;connect.
        </h2>
      </div>

      <div class="services-cards">
        {services.map((service, i) => (
          <a href={`/services/${service.slug}/`} class:list={['service-card', { 'service-card--accent': i === 0 || i === 4 }]}>
            <div class="service-top">
              <span class="service-index">{String(i + 1).padStart(2, '0')}</span>
              <span class="service-link" aria-hidden="true">&rarr;</span>
            </div>
            <h3 class="service-title">{service.title}</h3>
            <p class="service-desc">{service.shortDescription}</p>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .services-section {
    background-color: var(--color-black);
    color: var(--color-off-white);
    border-top: 6px solid var(--color-electric-yellow);
  }

  /* ---- Asymmetric layout ---- */
  .services-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
  }

  @media (min-width: 1024px) {
    .services-layout {
      grid-template-columns: 1fr 2fr;
      gap: var(--space-8);
      align-items: start;
    }
  }

  /* ---- Header — sticky on left at desktop ---- */
  .services-header {
    /* stays left */
  }

  @media (min-width: 1024px) {
    .services-header {
      position: sticky;
      top: calc(76px + var(--space-7));
    }
  }

  .services-eyebrow {
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-electric-yellow);
    margin-bottom: var(--space-3);
  }

  .services-heading {
    font-size: var(--fs-3xl);
    line-height: 1;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-off-white);
  }

  /* ---- Cards grid — 2-col on right side ---- */
  .services-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .services-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ---- Service card ---- */
  .service-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-5);
    background: transparent;
    border: 2px solid rgba(247, 244, 239, 0.15);
    text-decoration: none;
    color: var(--color-off-white);
    transition:
      transform 80ms ease,
      border-color 120ms ease,
      box-shadow 80ms ease;
  }

  .service-card:hover {
    border-color: var(--color-electric-yellow);
    box-shadow: 5px 5px 0 var(--color-electric-yellow);
    transform: translate(-3px, -3px);
  }

  /* Accent cards — yellow border from the start */
  .service-card--accent {
    border-color: var(--color-electric-yellow);
    border-width: 3px;
  }

  .service-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-4);
  }

  .service-index {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    color: var(--color-electric-yellow);
    letter-spacing: 0.1em;
  }

  .service-link {
    font-size: var(--fs-lg);
    color: var(--color-electric-yellow);
    transition: transform 120ms ease;
  }

  .service-card:hover .service-link {
    transform: translateX(4px);
  }

  .service-title {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--color-off-white);
    margin-bottom: var(--space-3);
    line-height: 1.1;
  }

  .service-desc {
    font-size: var(--fs-xs);
    color: var(--color-off-white);
    opacity: 0.6;
    line-height: 1.5;
    flex-grow: 1;
    max-width: none;
  }
</style>
