---
// ServicesOverview.astro — NEOBRUTALIST services grid
// Thick borders, hard shadows, bold type. No soft cards.

import { services } from '@data/services';
---

<section class="services-section section" aria-labelledby="services-heading">
  <!-- Black background with off-white text -->
  <div class="container">
    <div class="services-header">
      <p class="services-eyebrow">What We Do</p>
      <h2 class="services-heading" id="services-heading">
        Full-service 3PL. One call to connect.
      </h2>
    </div>

    <div class="services-grid">
      {services.map((service, i) => (
        <a href={`/services/${service.slug}/`} class="service-card">
          <span class="service-index">{String(i + 1).padStart(2, '0')}</span>
          <h3 class="service-title">{service.title}</h3>
          <p class="service-desc">{service.shortDescription}</p>
          <span class="service-link" aria-hidden="true">Learn more &rarr;</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    background-color: var(--color-black);
    color: var(--color-off-white);
    border-top: 6px solid var(--color-electric-yellow);
  }

  .services-header {
    margin-bottom: var(--space-8);
  }

  .services-eyebrow {
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-electric-yellow);
    margin-bottom: var(--space-3);
  }

  .services-heading {
    font-size: var(--fs-3xl);
    line-height: 1;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-off-white);
    max-width: 20ch;
  }

  /* ---- Grid ---- */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ---- Service card — BRUTALIST ---- */
  .service-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-5);
    background: transparent;
    border: 3px solid rgba(247, 244, 239, 0.2);
    text-decoration: none;
    color: var(--color-off-white);
    transition:
      transform 80ms ease,
      border-color 120ms ease,
      box-shadow 80ms ease;
  }

  .service-card:hover {
    border-color: var(--color-electric-yellow);
    box-shadow: 5px 5px 0 var(--color-electric-yellow);
    transform: translate(-3px, -3px);
  }

  .service-index {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-xs);
    font-weight: 800;
    color: var(--color-electric-yellow);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
  }

  .service-title {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--color-off-white);
    margin-bottom: var(--space-3);
    line-height: 1.1;
  }

  .service-desc {
    font-size: var(--fs-sm);
    color: var(--color-off-white);
    opacity: 0.7;
    line-height: 1.5;
    flex-grow: 1;
    max-width: none;
    margin-bottom: var(--space-4);
  }

  .service-link {
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 800;
    color: var(--color-electric-yellow);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: color 120ms ease;
  }

  .service-card:hover .service-link {
    color: var(--color-off-white);
  }
</style>
