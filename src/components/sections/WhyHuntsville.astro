---
// WhyHuntsville.astro — NEOBRUTALIST City character block
// Asymmetric layout, bold stat cards with hard shadows, industrial typography

import { city } from '@data/city';
---

<section class="why-section section" id="why-huntsville" aria-labelledby="why-heading">
  <div class="container">
    <!-- Section header — left-aligned, massive -->
    <div class="why-header">
      <p class="why-eyebrow">Why {city.name}?</p>
      <h2 class="why-heading" id="why-heading">
        Where rockets launch and freight lands.
      </h2>
    </div>

    <!-- Asymmetric content split -->
    <div class="why-content">
      <div class="why-body">
        <p class="text-lead">
          {city.name} sits at the convergence of I-65 and I-565 — the crossroads of
          the Southeast and the Midwest. The Port of {city.name} is one of the few
          fully integrated inland ports in the country, combining international air
          cargo, rail intermodal, and highway freight under a single authority, backed
          by more than $300 million in infrastructure investment.
        </p>
        <p>
          Within a one-day drive: Nashville, Atlanta, Memphis, Birmingham, Chattanooga,
          Louisville, and Knoxville. That's not a pitch. That's geography working in
          your favor.
        </p>
      </div>

      <!-- Stats — brutalist cards, staggered -->
      <div class="stats-grid">
        <div class="stat-card stat-card--offset-1">
          <span class="stat-number">21st</span>
          <span class="stat-label">in the U.S. for international air cargo volume</span>
        </div>
        <div class="stat-card stat-card--yellow">
          <span class="stat-number">$300M+</span>
          <span class="stat-label">invested in air and rail infrastructure</span>
        </div>
        <div class="stat-card stat-card--offset-2">
          <span class="stat-number">33,745</span>
          <span class="stat-label">rail lifts in 2024 — 22.3% YoY growth</span>
        </div>
        <div class="stat-card stat-card--red">
          <span class="stat-number">249K+</span>
          <span class="stat-label">residents — Alabama's largest and fastest-growing city</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .why-section {
    background-color: var(--color-off-white);
    border-top: 3px solid var(--color-black);
  }

  .why-header {
    margin-bottom: var(--space-8);
  }

  .why-eyebrow {
    font-family: var(--font-display);
    font-size: var(--fs-base);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-brick-red);
    margin-bottom: var(--space-3);
  }

  .why-heading {
    font-size: var(--fs-4xl);
    line-height: 1;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-black);
    max-width: 16ch;
  }

  /* ---- Asymmetric content split ---- */
  .why-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .why-content {
      grid-template-columns: 4fr 8fr;
      gap: var(--space-8);
    }
  }

  .why-body {
    max-width: none;
  }

  .why-body p {
    max-width: none;
    color: var(--color-black);
    font-size: var(--fs-md);
  }

  .why-body .text-lead {
    border-left: 4px solid var(--color-electric-yellow);
    padding-left: var(--space-5);
    margin-bottom: var(--space-5);
  }

  /* ---- Stats grid — 2x2, staggered offsets ---- */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-5);
    }
  }

  /* ---- Stat card — brutalist, hard shadow ---- */
  .stat-card {
    border: 3px solid var(--color-black);
    box-shadow: 5px 5px 0 var(--color-black);
    padding: var(--space-5);
    background: var(--color-off-white);
    transition:
      transform 80ms ease,
      box-shadow 80ms ease;
  }

  .stat-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 8px 8px 0 var(--color-black);
  }

  /* Yellow accent card */
  .stat-card--yellow {
    background: var(--color-electric-yellow);
  }

  /* Red accent card */
  .stat-card--red {
    background: var(--color-brick-red);
    color: var(--color-off-white);
  }

  .stat-card--red .stat-number {
    color: var(--color-electric-yellow);
  }

  .stat-card--red .stat-label {
    color: var(--color-off-white);
    opacity: 0.9;
  }

  /* Staggered offsets on larger screens */
  @media (min-width: 480px) {
    .stat-card--offset-1 {
      transform: translateY(0);
    }

    .stat-card--offset-2 {
      transform: translateY(var(--space-5));
    }

    .stat-card--offset-2:hover {
      transform: translate(-3px, calc(var(--space-5) - 3px));
    }
  }

  .stat-number {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 700;
    color: var(--color-black);
    line-height: 1;
    margin-bottom: var(--space-2);
    letter-spacing: -0.02em;
  }

  .stat-label {
    display: block;
    font-size: var(--fs-base);
    color: var(--color-black);
    line-height: 1.4;
    font-weight: 500;
  }
</style>
