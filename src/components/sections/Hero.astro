---
// Hero.astro — NEOBRUTALIST Homepage Hero
// Split: left content block with two-line headline + CTA, right photo
// Compact above-the-fold footprint — leaves more room for the next section
// to peek above the fold.

import { ctaNav } from '@data/navigation';
---

<section class="hero-split" aria-label="Homepage hero">
  <!-- Left: colored content block -->
  <div class="hero-content">
    <h1 class="hero-headline">
      <span class="headline-line">Huntsville's Premier Logistics</span>
      <span class="headline-line">Services</span>
    </h1>
    <a href={ctaNav.href} class="hero-cta">Connect</a>
  </div>

  <!-- Right: photo -->
  <div class="hero-photo">
    <img
      src="/images/hero-homepage.webp"
      alt="Huntsville, Alabama logistics and warehousing operations — Rocket City precision serving the Southeast"
      class="hero-img"
      width="1600"
      height="2114"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  </div>
</section>

<style>
  /* ---- Split: compact above-the-fold footprint ---- */
  .hero-split {
    display: flex;
    flex-direction: column;
    /* Tighter than before — the old layout filled the viewport.
       Now the hero is sized to its content with a sensible max,
       so the next section peeks above the fold on most screens. */
    min-height: clamp(380px, 56svh, 580px);
  }

  @media (min-width: 768px) {
    .hero-split {
      flex-direction: row;
    }
  }

  /* ---- Left: content block ---- */
  .hero-content {
    background-color: var(--color-off-white);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-5) var(--space-5) var(--space-5) 1.25rem;
    flex: 1;
  }

  @media (min-width: 768px) {
    .hero-content {
      flex: 0 0 59%;
      padding: var(--space-6) var(--space-6) var(--space-6) 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-content {
      padding: var(--space-6) var(--space-7) var(--space-7) 1.25rem;
    }
  }

  /* Two-line headline, broken intentionally:
     Line 1: "Huntsville's Premier Logistics"
     Line 2: "Services" (its own line for brutalist emphasis)

     Font reduced by 4px from the prior build — both ends of the
     clamp dropped by 0.25rem (3rem→2.75rem, 4.5rem→4.25rem). */
  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 5.25vw, 4.25rem);
    font-weight: 700;
    line-height: 1.04;
    color: var(--color-black);
    text-transform: none;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-5) 0;
    /* No max-width — first line should not wrap */
  }

  .headline-line {
    display: block;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-6);
    background-color: var(--color-brick-red);
    color: white;
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: 3px solid var(--color-black);
    box-shadow: 4px 4px 0 var(--color-black);
    transition:
      transform 80ms ease,
      box-shadow 80ms ease;
    white-space: nowrap;
    align-self: flex-start;
  }

  .hero-cta:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-black);
  }

  .hero-cta:active {
    transform: translate(3px, 3px);
    box-shadow: none;
  }

  /* ---- Right: photo fills its column ---- */
  .hero-photo {
    flex: 1;
    overflow: hidden;
    position: relative;
    min-height: 200px;
  }

  @media (min-width: 768px) {
    .hero-photo {
      flex: 0 0 41%;
    }
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
  }
</style>
