---
// Hero.astro — NEOBRUTALIST Homepage Hero
// Layout (desktop): left content block (headline + CTA) | photo anchored right.
// The photo is sized to a fixed height that fits above the fold; its width
// is computed from the image's intrinsic aspect ratio (1600/2114 = portrait),
// so the image scales proportionally — no distortion, no cropping.
// Off-white fills the gap between the content block and the photo.

import { ctaNav } from '@data/navigation';
---

<section class="hero-split" aria-label="Homepage hero">
  <!-- Left: colored content block -->
  <div class="hero-content">
    <h1 class="hero-headline">
      <span class="headline-line">Huntsville's Premier Logistics</span>
      <span class="headline-line">Services</span>
    </h1>
    <a href={ctaNav.href} class="hero-cta">Connect</a>
  </div>

  <!-- Right: photo anchored right edge, height-constrained -->
  <div class="hero-photo">
    <img
      src="/images/hero-homepage.webp"
      alt="Huntsville, Alabama logistics and warehousing operations — Rocket City precision serving the Southeast"
      class="hero-img"
      width="1600"
      height="2114"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  </div>
</section>

<style>
  /* ===== Section shell ===== */
  .hero-split {
    display: flex;
    flex-direction: column;
    background: var(--color-off-white);
  }

  @media (min-width: 768px) {
    .hero-split {
      flex-direction: row;
      align-items: stretch;
      /* Fill the remaining above-fold space below the BrandBanner + nav.
         200px ≈ BrandBanner (~150px) + Header nav (~50px). Section bottom
         border lands exactly at the viewport fold on any desktop viewport.
         Bounded so it doesn't collapse on very short screens. */
      min-height: clamp(380px, calc(100svh - 200px), 900px);
      max-height: calc(100svh - 200px);
    }
  }

  /* ===== Left: content block ===== */
  .hero-content {
    flex: 1;
    background-color: var(--color-off-white);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-5) var(--space-5) var(--space-5) 1.25rem;
  }

  @media (min-width: 768px) {
    .hero-content {
      padding: var(--space-6) var(--space-6) var(--space-6) 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-content {
      padding: var(--space-6) var(--space-7) var(--space-6) 1.25rem;
    }
  }

  /* Two-line headline — line 1: "Huntsville's Premier Logistics",
     line 2: "Services". Font sized 4px smaller than the v4 build. */
  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 5.25vw, 4.25rem);
    font-weight: 700;
    line-height: 1.04;
    color: var(--color-black);
    text-transform: none;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-5) 0;
  }

  .headline-line {
    display: block;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-6);
    background-color: var(--color-brick-red);
    color: white;
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: 3px solid var(--color-black);
    box-shadow: 4px 4px 0 var(--color-black);
    transition:
      transform 80ms ease,
      box-shadow 80ms ease;
    white-space: nowrap;
    align-self: flex-start;
  }

  .hero-cta:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-black);
  }

  .hero-cta:active {
    transform: translate(3px, 3px);
    box-shadow: none;
  }

  /* ===== Right: photo (anchored right, proportional) =====
     Mobile (column layout): photo sits below the content at full width,
       natural aspect ratio, no crop.
     Desktop (row layout): photo's HEIGHT matches the section height
       (clamped above ~460px), WIDTH is auto so the aspect ratio is
       preserved → no distortion. The photo container shrinks to wrap
       the image and is anchored to the right edge of the row. */
  .hero-photo {
    flex: 0 0 auto;
    background: var(--color-off-white);
    overflow: hidden;
    display: flex;
    justify-content: flex-end;
    align-items: stretch;
  }

  .hero-img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (min-width: 768px) {
    .hero-img {
      width: auto;
      height: 100%;
      max-height: calc(100svh - 200px);
    }
  }
</style>
