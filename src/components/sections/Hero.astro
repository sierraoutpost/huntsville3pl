---
// Hero.astro — NEOBRUTALIST Homepage Hero (v3)
// Tyler's Figma wireframe requirements:
// - EVERYTHING fits in one viewport (100svh minus header)
// - Left side: headline + services list + CTAs
// - Right side: photo, offset, fits in viewport
// - Photo does NOT need to align with nav — intentional asymmetry
// Non-Negotiable #28: Every page has a real photograph in the hero banner

import { city } from '@data/city';
import { ctaNav } from '@data/navigation';
import { brand } from '@data/brand';
---

<section class="hero" aria-label="Homepage hero">
  <!-- Electric yellow accent strip at top -->
  <div class="hero-strip"></div>

  <div class="hero-layout">
    <!-- LEFT COLUMN: headline + services + CTAs -->
    <div class="hero-left">
      <p class="hero-eyebrow">{brand.name} // {city.name}</p>

      <h1 class="hero-title">
        <span class="hero-title-line">The Rocket City</span>
        <span class="hero-title-line hero-title-accent">runs on</span>
        <span class="hero-title-line">precision.</span>
      </h1>

      <ul class="hero-services" role="list">
        <li>Warehousing</li>
        <li>Fulfillment</li>
        <li>Cross-docking</li>
        <li>Transloading</li>
        <li>Transportation</li>
        <li>Kitting</li>
        <li>Returns</li>
      </ul>

      <p class="hero-sub">
        Powered by {city.name}'s world-class logistics infrastructure.
      </p>

      <div class="hero-actions">
        <a href={ctaNav.href} class="hero-btn hero-btn--primary">Connect</a>
        <a href={brand.phone.href} class="hero-btn hero-btn--phone">{brand.phone.display}</a>
      </div>
    </div>

    <!-- RIGHT COLUMN: photo -->
    <div class="hero-right">
      <div class="hero-image-wrap">
        <img
          src="/images/hero-huntsville.webp"
          alt="U.S. Space and Rocket Center in Huntsville, Alabama"
          class="hero-img"
          width="1080"
          height="607"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--color-off-white);
    position: relative;
    overflow: hidden;
  }

  .hero-strip {
    height: 6px;
    background-color: var(--color-electric-yellow);
    flex-shrink: 0;
  }

  /* ---- TWO-COLUMN LAYOUT — fits in viewport ---- */
  .hero-layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-4) clamp(1rem, 3vw, 2rem);
    min-height: calc(100svh - 82px); /* viewport minus header height */
  }

  @media (min-width: 768px) {
    .hero-layout {
      flex-direction: row;
      align-items: center;
      gap: var(--space-6);
      padding: var(--space-4) clamp(1.5rem, 3vw, 2.5rem);
    }
  }

  @media (min-width: 1024px) {
    .hero-layout {
      padding: var(--space-5) clamp(2rem, 4vw, 3.5rem);
      gap: var(--space-7);
    }
  }

  /* ---- LEFT COLUMN ---- */
  .hero-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  @media (min-width: 768px) {
    .hero-left {
      flex: 0 1 50%;
    }
  }

  @media (min-width: 1024px) {
    .hero-left {
      flex: 0 1 45%;
    }
  }

  /* ---- Eyebrow ---- */
  .hero-eyebrow {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-rocket-silver);
    margin-bottom: var(--space-3);
    max-width: none;
  }

  /* ---- Headline — large but must fit with everything else ---- */
  .hero-title {
    font-size: clamp(2.5rem, 5.5vw, 5rem);
    line-height: 0.92;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-black);
    margin-bottom: var(--space-4);
    max-width: none;
  }

  .hero-title-line {
    display: block;
  }

  .hero-title-accent {
    color: var(--color-brick-red);
  }

  /* ---- Services listed individually ---- */
  .hero-services {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: var(--space-2);
  }

  .hero-services li {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-black);
    line-height: 1.7;
  }

  .hero-sub {
    font-size: var(--fs-xs);
    line-height: 1.5;
    color: var(--color-rocket-silver);
    max-width: 36ch;
    margin-bottom: var(--space-4);
  }

  /* ---- CTA buttons — both same style ---- */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-5);
    font-family: var(--font-display);
    font-size: var(--fs-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: 3px solid var(--color-black);
    box-shadow: 4px 4px 0 var(--color-black);
    transition:
      transform 80ms ease,
      box-shadow 80ms ease;
    white-space: nowrap;
  }

  .hero-btn:active {
    transform: translate(3px, 3px);
    box-shadow: none;
  }

  .hero-btn--primary {
    background-color: var(--color-brick-red);
    color: var(--color-off-white);
  }

  .hero-btn--primary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-black);
  }

  .hero-btn--phone {
    background-color: var(--color-off-white);
    color: var(--color-black);
  }

  .hero-btn--phone:hover {
    background-color: var(--color-black);
    color: var(--color-off-white);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-black);
  }

  /* ---- RIGHT COLUMN: photo ---- */
  .hero-right {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    min-width: 0;
  }

  @media (min-width: 768px) {
    .hero-right {
      flex: 0 1 50%;
    }
  }

  @media (min-width: 1024px) {
    .hero-right {
      flex: 0 1 55%;
      /* Intentional asymmetry: push photo past right edge */
      margin-right: -1.5rem;
    }
  }

  .hero-image-wrap {
    border: 3px solid var(--color-black);
    box-shadow: 8px 8px 0 var(--color-black);
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .hero-image-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 40px;
    height: 40px;
    background-color: var(--color-electric-yellow);
    clip-path: polygon(0 0, 100% 0, 100% 100%);
  }

  .hero-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 16 / 9;
  }
</style>
