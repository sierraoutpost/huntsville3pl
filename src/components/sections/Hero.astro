---
// Hero.astro — NEOBRUTALIST Homepage Hero (v4) — Row 3 only
// Split: left colored block with headline + CTA, right photo
// Fills remaining viewport after BrandBanner + Header

import { ctaNav } from '@data/navigation';
---

<section class="hero-split" aria-label="Homepage hero">
  <!-- Left: colored content block -->
  <div class="hero-content">
    <h1 class="hero-headline">
      Huntsville's Premier Logistics Services
    </h1>
    <a href={ctaNav.href} class="hero-cta">Connect</a>
  </div>

  <!-- Right: photo -->
  <div class="hero-photo">
    <img
      src="/images/hero-huntsville.webp"
      alt="U.S. Space and Rocket Center in Huntsville, Alabama"
      class="hero-img"
      width="1080"
      height="607"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  </div>
</section>

<style>
  /* ---- Split fills remaining viewport ---- */
  .hero-split {
    display: flex;
    flex-direction: column;
    /* viewport minus banner (~150px) minus nav bar (~58px) */
    min-height: calc(100svh - 210px);
  }

  @media (min-width: 768px) {
    .hero-split {
      flex-direction: row;
    }
  }

  /* ---- Left: content block ---- */
  .hero-content {
    background-color: var(--color-off-white);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-6) var(--space-5);
    flex: 1;
  }

  @media (min-width: 768px) {
    .hero-content {
      flex: 0 0 40%;
      padding: var(--space-7) var(--space-6);
    }
  }

  @media (min-width: 1024px) {
    .hero-content {
      padding: var(--space-8) var(--space-7);
    }
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 700;
    line-height: 1.05;
    color: var(--color-black);
    text-transform: none;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-5);
    max-width: 14ch;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-6);
    background-color: var(--color-brick-red);
    color: white;
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: 3px solid var(--color-black);
    box-shadow: 4px 4px 0 var(--color-black);
    transition:
      transform 80ms ease,
      box-shadow 80ms ease;
    white-space: nowrap;
    align-self: flex-start;
  }

  .hero-cta:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-black);
  }

  .hero-cta:active {
    transform: translate(3px, 3px);
    box-shadow: none;
  }

  /* ---- Right: photo fills space ---- */
  .hero-photo {
    flex: 1;
    overflow: hidden;
    position: relative;
    min-height: 200px;
  }

  @media (min-width: 768px) {
    .hero-photo {
      flex: 0 0 60%;
    }
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }
</style>
