---
// Hero.astro — NEOBRUTALIST Homepage Hero
// Full-viewport photo (Cargolux 747 freighter at night) with headline,
// tagline, and Connect CTA overlaid in the upper-left corner.
// Fills the entire above-fold viewport below the BrandBanner + Header.

import { ctaNav } from '@data/navigation';
---

<section class="hero" aria-label="Homepage hero">
  <img
    src="/images/cargolux-hero.webp"
    alt="Cargolux Boeing 747 freighter on the tarmac at night — Huntsville 3PL air cargo logistics serving aerospace, defense, manufacturing, e-commerce, and global supply chain operations"
    class="hero-img"
    width="2560"
    height="1707"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />

  <div class="hero-overlay">
    <h1 class="hero-headline">
      Huntsville's Premier<br />
      Logistics Services
    </h1>
    <p class="hero-tagline">Building Supply Chain Solutions</p>
    <a href={ctaNav.href} class="hero-cta">Connect</a>
  </div>
</section>

<style>
  /* ===== Full-viewport hero =====
     Fills the above-fold space below BrandBanner (~150px) + Header (~50px).
     200px offset keeps the bottom border at the fold. */
  .hero {
    position: relative;
    height: clamp(380px, calc(100svh - 200px), 900px);
    overflow: hidden;
    background: var(--color-black);
    border-bottom: 3px solid var(--color-black);
  }

  /* Photo fits entirely within the section — no cropping.
     object-fit: contain keeps the full image visible; the black
     background fills any letterbox space on ultra-wide viewports. */
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center bottom;
    display: block;
  }

  /* ===== Text overlay — upper-left corner ===== */
  .hero-overlay {
    position: absolute;
    top: var(--space-5);
    left: 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
    max-width: 680px;
  }

  @media (min-width: 768px) {
    .hero-overlay {
      top: var(--space-6);
      left: var(--space-6);
    }
  }

  @media (min-width: 1024px) {
    .hero-overlay {
      top: var(--space-7);
      left: var(--space-7);
    }
  }

  /* Headline — white, large, fluid */
  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4.25rem);
    font-weight: 700;
    line-height: 1.04;
    color: white;
    text-transform: none;
    letter-spacing: -0.02em;
    margin: 0;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.5), 0 1px 4px rgba(0, 0, 0, 0.35);
  }

  /* Tagline — white, lighter weight */
  .hero-tagline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.35rem);
    font-weight: 500;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.45);
  }

  /* CTA button — brick-red, neobrutalist style */
  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-6);
    background-color: var(--color-brick-red);
    color: white;
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: 3px solid var(--color-black);
    box-shadow: 4px 4px 0 var(--color-black);
    transition:
      transform 80ms ease,
      box-shadow 80ms ease;
    white-space: nowrap;
    margin-top: var(--space-2);
  }

  .hero-cta:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-black);
  }

  .hero-cta:active {
    transform: translate(3px, 3px);
    box-shadow: none;
  }
</style>
