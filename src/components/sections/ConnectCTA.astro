---
// ConnectCTA.astro — Bottom-of-page Connect call to action
// Source: 08-forms-and-connect-cta.md
// Non-Negotiable #17: CTA is always "Connect"

import { brand } from '@data/brand';
import { city } from '@data/city';
import { ctaNav } from '@data/navigation';
---

<section class="cta-section section" aria-labelledby="cta-heading">
  <div class="container cta-container">
    <p class="cta-eyebrow text-caps">{brand.hours}</p>
    <h2 class="cta-heading" id="cta-heading">
      Ready to move freight<br class="hide-mobile" /> through the Rocket City?
    </h2>
    <p class="cta-body">
      Whether you need warehousing, fulfillment, cross-docking, or a full logistics
      strategy — our {city.name} team is standing by. No phone tree. No hold music.
      Real people, real answers.
    </p>
    <div class="cta-actions">
      <a href={ctaNav.href} class="btn btn-cta-primary">Connect With Us</a>
      <a href={brand.phone.href} class="btn btn-cta-phone">{brand.phone.display}</a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background-color: var(--color-off-white);
    text-align: center;
  }

  .cta-container {
    max-width: 700px;
  }

  .cta-eyebrow {
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .cta-heading {
    font-size: var(--fs-3xl);
    margin-bottom: var(--space-5);
  }

  .hide-mobile {
    display: none;
  }

  @media (min-width: 768px) {
    .hide-mobile {
      display: inline;
    }
  }

  .cta-body {
    font-size: var(--fs-md);
    line-height: 1.6;
    margin-inline: auto;
    margin-bottom: var(--space-6);
    max-width: 55ch;
  }

  /* ---- Buttons ---- */
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
  }

  .btn-cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-7);
    background-color: var(--color-cta);
    color: var(--color-off-white);
    font-family: var(--font-body);
    font-size: var(--fs-base);
    font-weight: 500;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background-color var(--transition-fast), transform 80ms ease;
    white-space: nowrap;
  }

  .btn-cta-primary:hover {
    background-color: var(--color-cta-hover);
  }

  .btn-cta-primary:active {
    transform: scale(0.95);
  }

  .btn-cta-phone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-7);
    background: transparent;
    color: var(--color-petrol-blue);
    font-family: var(--font-body);
    font-size: var(--fs-base);
    font-weight: 500;
    text-decoration: none;
    border: 1.5px solid var(--color-petrol-blue);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-fast), color var(--transition-fast), background-color var(--transition-fast);
    white-space: nowrap;
  }

  .btn-cta-phone:hover {
    border-color: var(--color-cta);
    color: var(--color-cta);
    background: rgba(139, 31, 36, 0.04);
  }
</style>
