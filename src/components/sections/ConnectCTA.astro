---
// ConnectCTA.astro — NEOBRUTALIST bottom-of-page Connect CTA
// Non-Negotiable #17: CTA is always "Connect"
// Electric yellow background — impossible to miss

import { brand } from '@data/brand';
import { city } from '@data/city';
import { ctaNav } from '@data/navigation';
---

<section class="cta-section" aria-labelledby="cta-heading">
  <div class="container cta-container">
    <p class="cta-eyebrow">{brand.hours}</p>
    <h2 class="cta-heading" id="cta-heading">
      Ready to move freight through the Rocket City?
    </h2>
    <p class="cta-body">
      Whether you need warehousing, fulfillment, cross-docking, or a full logistics
      strategy — our {city.name} team is standing by. No phone tree. No hold music.
      Real people, real answers.
    </p>
    <div class="cta-actions">
      <a href={ctaNav.href} class="cta-btn-primary">Connect With Us</a>
      <a href={brand.phone.href} class="cta-btn-phone">{brand.phone.display}</a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background-color: var(--color-electric-yellow);
    border-top: 4px solid var(--color-black);
    border-bottom: 4px solid var(--color-black);
    padding-block: var(--space-9);
  }

  @media (min-width: 1024px) {
    .cta-section {
      padding-block: var(--space-10);
    }
  }

  .cta-container {
    max-width: 800px;
    text-align: center;
  }

  .cta-eyebrow {
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-black);
    opacity: 0.6;
    margin-bottom: var(--space-4);
  }

  .cta-heading {
    font-size: var(--fs-4xl);
    line-height: 0.95;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-black);
    margin-bottom: var(--space-5);
  }

  .cta-body {
    font-size: var(--fs-md);
    line-height: 1.6;
    color: var(--color-black);
    margin-inline: auto;
    margin-bottom: var(--space-7);
    max-width: 55ch;
    font-weight: 500;
  }

  /* ---- CTA Buttons ---- */
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
  }

  .cta-btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-7);
    background-color: var(--color-black);
    color: var(--color-electric-yellow);
    font-family: var(--font-display);
    font-size: var(--fs-base);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: 3px solid var(--color-black);
    box-shadow: 5px 5px 0 var(--color-brick-red);
    transition:
      transform 80ms ease,
      box-shadow 80ms ease;
    white-space: nowrap;
  }

  .cta-btn-primary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 var(--color-brick-red);
  }

  .cta-btn-primary:active {
    transform: translate(3px, 3px);
    box-shadow: none;
  }

  .cta-btn-phone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-7);
    background: transparent;
    color: var(--color-black);
    font-family: var(--font-display);
    font-size: var(--fs-base);
    font-weight: 800;
    text-decoration: none;
    border: 3px solid var(--color-black);
    box-shadow: 5px 5px 0 var(--color-black);
    transition:
      transform 80ms ease,
      box-shadow 80ms ease,
      background-color 120ms ease;
    white-space: nowrap;
  }

  .cta-btn-phone:hover {
    background-color: var(--color-black);
    color: var(--color-electric-yellow);
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 var(--color-black);
  }

  .cta-btn-phone:active {
    transform: translate(3px, 3px);
    box-shadow: none;
  }
</style>
