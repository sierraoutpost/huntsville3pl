---
// ConnectForm.astro — Brutalist contact form
// Chunk 2: form structure, styles, Zapier webhook wiring, mailto fallback
// Chunk 3 will add side cards to the right of this form
// Chunk 4 will apply the damier dissolve effect to the .form-region wrapper

import { brand } from '@data/brand';
import { services } from '@data/services';

// Zapier Catch Hook — posts JSON payload of the form on submit
const ZAPIER_WEBHOOK = 'https://hooks.zapier.com/hooks/catch/25782870/ujycfzd/';
---

<section class="form-region" aria-labelledby="form-heading" data-form-region>
  <div class="form-wrap">
    <header class="form-header">
      <h2 class="form-heading" id="form-heading">Send Us A Message</h2>
      <p class="form-sub">
        Whether you want pricing or just a quick question, drop us a line.
        Fields marked optional are only for quote requests.
      </p>
    </header>

    <!--
      Form strategy:
      - Default `action` is a mailto: fallback so the form works even with JS disabled.
      - Client JS (below) intercepts submit, POSTs JSON to the Zapier Catch Hook,
        and shows success/error states. mailto: is prevented on success.
    -->
    <form
      class="connect-form"
      name="huntsville-connect"
      method="POST"
      action={brand.email.href}
      enctype="text/plain"
      data-connect-form
      data-webhook={ZAPIER_WEBHOOK}
      novalidate
    >
      <!-- Row 1: Name + Email (both required) -->
      <div class="field-row">
        <label class="field">
          <span class="field-label">Name <span class="req" aria-hidden="true">*</span></span>
          <input
            class="field-input"
            type="text"
            name="name"
            required
            autocomplete="name"
            placeholder="Your name"
          />
        </label>

        <label class="field">
          <span class="field-label">Email <span class="req" aria-hidden="true">*</span></span>
          <input
            class="field-input"
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="you@company.com"
          />
        </label>
      </div>

      <!-- Row 2: Phone + Company (both optional) -->
      <div class="field-row">
        <label class="field">
          <span class="field-label">Phone</span>
          <input
            class="field-input"
            type="tel"
            name="phone"
            autocomplete="tel"
            placeholder="(555) 123-4567"
          />
        </label>

        <label class="field">
          <span class="field-label">Company</span>
          <input
            class="field-input"
            type="text"
            name="company"
            autocomplete="organization"
            placeholder="Your company (optional)"
          />
        </label>
      </div>

      <!-- Reason -->
      <label class="field field--full">
        <span class="field-label">What's this about?</span>
        <select class="field-input field-input--select" name="reason">
          <option value="">Select a reason (optional)</option>
          <option value="quote">Request a quote</option>
          <option value="question">General question</option>
          <option value="partnership">Partnership / referral</option>
          <option value="carrier-vendor">Carrier or vendor inquiry</option>
          <option value="career">Careers</option>
          <option value="other">Other</option>
        </select>
      </label>

      <!-- Quote details group -->
      <fieldset class="quote-group">
        <legend class="quote-legend">
          Quote Details <span class="quote-hint">(Optional — select N/A if not requesting pricing)</span>
        </legend>

        <div class="field-row">
          <label class="field">
            <span class="field-label">Service of Interest</span>
            <select class="field-input field-input--select" name="service">
              <option value="">Select...</option>
              {services.map((s) => (
                <option value={s.slug}>{s.title}</option>
              ))}
              <option value="not-sure">Not sure yet</option>
              <option value="na">N/A</option>
            </select>
          </label>

          <label class="field">
            <span class="field-label">Estimated Volume</span>
            <select class="field-input field-input--select" name="volume">
              <option value="">Select...</option>
              <option value="<100">Less than 100 orders/month</option>
              <option value="100-1k">100 – 1,000 orders/month</option>
              <option value="1k-10k">1,000 – 10,000 orders/month</option>
              <option value="10k+">10,000+ orders/month</option>
              <option value="na">N/A</option>
            </select>
          </label>
        </div>

        <div class="field-row">
          <label class="field">
            <span class="field-label">Origin</span>
            <input
              class="field-input"
              type="text"
              name="origin"
              placeholder="City, State or N/A"
            />
          </label>

          <label class="field">
            <span class="field-label">Destination</span>
            <input
              class="field-input"
              type="text"
              name="destination"
              placeholder="City, State or N/A"
            />
          </label>
        </div>

        <label class="field field--full">
          <span class="field-label">Timeline</span>
          <select class="field-input field-input--select" name="timeline">
            <option value="">Select...</option>
            <option value="asap">ASAP</option>
            <option value="<30">Less than 30 days</option>
            <option value="30-90">30 – 90 days</option>
            <option value="90+">90+ days</option>
            <option value="exploring">Just exploring</option>
            <option value="na">N/A</option>
          </select>
        </label>
      </fieldset>

      <!-- Message (required) -->
      <label class="field field--full">
        <span class="field-label">Message <span class="req" aria-hidden="true">*</span></span>
        <textarea
          class="field-input field-textarea"
          name="message"
          required
          rows="6"
          placeholder="Tell us what you need — a quick hello, a question, or details on a quote request."
        />
      </label>

      <!-- Honeypot: bots fill this in, humans don't see it. Submissions with
           a non-empty value are silently discarded client-side. -->
      <label class="honeypot" aria-hidden="true">
        Leave this field empty
        <input type="text" name="website" tabindex="-1" autocomplete="off" />
      </label>

      <!-- Submit + status area -->
      <div class="form-footer">
        <button type="submit" class="submit-btn" data-submit>
          <span class="submit-label">Send Message</span>
          <span class="submit-arrow" aria-hidden="true">→</span>
        </button>

        <p class="form-status" data-form-status role="status" aria-live="polite"></p>
      </div>
    </form>

    <!-- Form-fade overlay: covers the form (only) once the shatter
         starts, leaving just the confirmation card on screen. -->
    <div class="form-fade" data-form-fade aria-hidden="true"></div>
  </div>

  <!-- Shatter stage: JS positions this over the button at click time
       and fills it with a grid of tiles that animate outward. -->
  <div class="shatter-stage" data-shatter-stage aria-hidden="true"></div>
</section>

<!-- Confirmation card — viewport-centered, hidden until the button
     finishes shattering. The "X" close button navigates home. -->
<div
  class="confirm-card"
  data-confirm-card
  role="dialog"
  aria-modal="true"
  aria-labelledby="confirm-title"
  hidden
>
  <button
    type="button"
    class="confirm-close"
    data-confirm-close
    aria-label="Close this page and return to homepage"
  >
    <span class="confirm-close-x" aria-hidden="true">×</span>
    <span class="confirm-close-text">Close this page and return to homepage</span>
  </button>

  <p class="confirm-eyebrow">Message Sent</p>
  <h2 class="confirm-title" id="confirm-title">Thank You</h2>
  <p class="confirm-body">
    Your message has been sent. We will reach out within the next 24 hours.
  </p>
</div>

<style>
  /* =============================================================
     FORM REGION — fills its grid column; parent page owns the layout
     ============================================================= */
  .form-region {
    position: relative;
    background: var(--color-off-white);
  }

  .form-wrap {
    padding: 0;
  }

  /* =============================================================
     FORM HEADER
     ============================================================= */
  .form-header {
    margin-bottom: var(--space-5);
  }

  .form-heading {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.25vw, 2.75rem);
    font-weight: 700;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--color-black);
    text-transform: uppercase;
    margin: 0 0 var(--space-2) 0;
  }

  .form-sub {
    font-family: var(--font-body);
    font-size: var(--fs-base);
    line-height: 1.5;
    color: var(--color-black);
    opacity: 0.8;
    margin: 0;
    max-width: 55ch;
  }

  /* =============================================================
     FIELDS — brutalist: thick black borders, no radius, hard focus
     ============================================================= */
  .connect-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .field-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field--full {
    grid-column: 1 / -1;
  }

  .field-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-black);
  }

  .req {
    color: var(--color-brick-red);
    margin-left: 0.15em;
  }

  .field-input {
    font-family: var(--font-body);
    font-size: var(--fs-base);
    line-height: 1.3;
    padding: 0.85rem 0.9rem;
    background: white;
    color: var(--color-black);
    border: 3px solid var(--color-black);
    border-radius: 0;
    outline: none;
    appearance: none;
    -webkit-appearance: none;
    transition: box-shadow 120ms ease, transform 120ms ease;
  }

  .field-input::placeholder {
    color: var(--color-black);
    opacity: 0.4;
  }

  .field-input:focus {
    /* Hard offset shadow — brutalist "pop" */
    box-shadow: 6px 6px 0 var(--color-electric-yellow);
    transform: translate(-2px, -2px);
  }

  .field-input:invalid:not(:placeholder-shown) {
    box-shadow: 6px 6px 0 var(--color-brick-red);
  }

  .field-textarea {
    resize: vertical;
    min-height: 160px;
    font-family: var(--font-body);
  }

  /* Custom dropdown chevron — brutalist, square, black */
  .field-input--select {
    background-image: linear-gradient(45deg, transparent 50%, var(--color-black) 50%),
      linear-gradient(135deg, var(--color-black) 50%, transparent 50%);
    background-position: calc(100% - 22px) 55%, calc(100% - 14px) 55%;
    background-size: 8px 8px, 8px 8px;
    background-repeat: no-repeat;
    padding-right: 3rem;
    cursor: pointer;
  }

  /* =============================================================
     QUOTE DETAILS GROUP — bordered subsection
     ============================================================= */
  .quote-group {
    border: 3px solid var(--color-black);
    background: white;
    padding: var(--space-4);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .quote-group {
      padding: var(--space-5);
    }
  }

  .quote-legend {
    font-family: var(--font-display);
    font-size: var(--fs-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-black);
    background: var(--color-electric-yellow);
    border: 3px solid var(--color-black);
    padding: 0.35rem 0.65rem;
    margin-left: -3px;
  }

  .quote-hint {
    font-weight: 500;
    letter-spacing: 0.08em;
    opacity: 0.75;
    margin-left: 0.5ch;
  }

  /* =============================================================
     HONEYPOT — hidden from users, visible to dumb bots
     ============================================================= */
  .honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  /* =============================================================
     SUBMIT — brutalist CTA button
     ============================================================= */
  .form-footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    width: 100%;
    padding: 1.1rem 1.4rem;
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-electric-yellow);
    background: var(--color-black);
    border: 3px solid var(--color-black);
    border-radius: 0;
    cursor: pointer;
    transition: transform 120ms ease, box-shadow 120ms ease, background-color 120ms ease;
    box-shadow: 6px 6px 0 var(--color-brick-red);
  }

  @media (min-width: 640px) {
    .submit-btn {
      width: auto;
      min-width: 280px;
    }
  }

  .submit-btn:hover,
  .submit-btn:focus-visible {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 var(--color-brick-red);
    outline: none;
  }

  .submit-btn:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 var(--color-brick-red);
  }

  .submit-btn[data-pending='true'] {
    cursor: wait;
    opacity: 0.7;
  }

  .submit-arrow {
    font-size: 1.5em;
    line-height: 1;
  }

  /* Status message — success or error */
  .form-status {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: 600;
    line-height: 1.4;
    margin: 0;
    padding: 0;
    min-height: 1.4em;
  }

  .form-status[data-state='success'] {
    color: #0a6d0a;
    padding: 0.65rem 0.8rem;
    background: #eaf7ea;
    border: 3px solid #0a6d0a;
  }

  .form-status[data-state='error'] {
    color: var(--color-brick-red);
    padding: 0.65rem 0.8rem;
    background: #fbeaea;
    border: 3px solid var(--color-brick-red);
  }

  /* =============================================================
     SHATTER + CONFIRMATION
     -------------------------------------------------------------
     On successful submit:
       1. The Send button is "hidden in place" (visibility:hidden so
          its layout footprint stays — no jump).
       2. JS positions .shatter-stage (position:fixed) over the button
          and fills it with a grid of small black tiles. Each tile gets
          random outward translate / rotate / delay variables.
       3. CSS animation runs the tiles outward + rotates + fades.
       4. Mid-shatter, .form-fade overlays the form-wrap with off-white
          (covers the entire form). Confirmation card materializes,
          centered on the viewport.
       5. Reduced-motion: skip the tile animation, jump straight to the
          confirmation card.
     ============================================================= */

  /* SHATTER STAGE — viewport-fixed container that holds the tiles.
     JS sets top/left/width/height to match the button's bounding rect. */
  .shatter-stage {
    position: fixed;
    pointer-events: none;
    z-index: 90;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
  }

  /* Tile styles + keyframes live in a separate :global block below
     because they're applied to JS-created elements (no scope hash). */

  /* FORM FADE — covers the form-wrap (so only the confirmation card
     remains visible after the shatter completes). */
  .form-wrap {
    position: relative;
  }

  .form-fade {
    position: absolute;
    inset: -1rem;
    background: var(--color-off-white);
    opacity: 0;
    pointer-events: none;
    z-index: 50;
    transition: opacity 420ms ease-out;
  }

  .form-fade[data-active='true'] {
    opacity: 1;
    pointer-events: auto;
  }

  /* CONFIRMATION CARD — viewport-centered, brutalist styling.
     Hidden by default via the [hidden] attribute; JS removes [hidden]
     and adds data-active='true' to fade in. */
  .confirm-card {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.96);
    z-index: 200;
    width: min(92vw, 560px);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    background: var(--color-black);
    color: var(--color-off-white);
    border: 4px solid var(--color-black);
    box-shadow: 10px 10px 0 var(--color-brick-red);
    opacity: 0;
    transition: opacity 320ms ease-out, transform 320ms ease-out;
    text-align: center;
  }

  .confirm-card[data-active='true'] {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  .confirm-eyebrow {
    font-family: var(--font-display);
    font-size: var(--fs-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-electric-yellow);
    margin: 0 0 var(--space-3) 0;
  }

  .confirm-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.0;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--color-off-white);
    margin: 0 0 var(--space-4) 0;
  }

  .confirm-body {
    font-family: var(--font-body);
    font-size: var(--fs-base);
    line-height: 1.5;
    color: var(--color-off-white);
    opacity: 0.9;
    margin: 0;
  }

  /* Close button — styled as a small brutalist link/button at the
     top-right of the card. Says exactly what it does. */
  .confirm-close {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.6rem;
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-black);
    background: var(--color-electric-yellow);
    border: 2px solid var(--color-electric-yellow);
    cursor: pointer;
    transition: transform 120ms ease, box-shadow 120ms ease;
  }

  .confirm-close:hover,
  .confirm-close:focus-visible {
    transform: translate(-2px, -2px);
    box-shadow: 3px 3px 0 var(--color-off-white);
    outline: none;
  }

  .confirm-close-x {
    font-family: var(--font-display);
    font-size: 1.1rem;
    line-height: 1;
  }

  .confirm-close-text {
    line-height: 1.1;
    text-align: left;
  }

  /* Accessibility — skip the tile animation for motion-sensitive
     users. The confirmation card still appears, just without the
     shatter spectacle. */
  @media (prefers-reduced-motion: reduce) {
    .shatter-tile {
      animation: none;
      opacity: 0;
    }
    .form-fade,
    .confirm-card {
      transition: none;
    }
  }
</style>

<!-- Global styles for the shatter tiles. These apply to elements
     created at runtime by JS, which do NOT carry Astro's scope hash. -->
<style is:global>
  .shatter-tile {
    position: absolute;
    width: 12px;
    height: 12px;
    background: #0A0A0A;
    transform-origin: center;
    will-change: transform, opacity;
    --tx: 0px;
    --ty: 0px;
    --r: 0deg;
    --s: 1;
    animation: hsv3pl-shatter-fly 1100ms cubic-bezier(0.16, 0.84, 0.44, 1) forwards;
  }

  @keyframes hsv3pl-shatter-fly {
    0% {
      transform: translate(0, 0) rotate(0deg) scale(1);
      opacity: 1;
    }
    35% {
      transform:
        translate(calc(var(--tx) * 0.55), calc(var(--ty) * 0.55 - 30px))
        rotate(calc(var(--r) * 0.4))
        scale(calc(var(--s) * 1.15));
      opacity: 1;
    }
    100% {
      transform:
        translate(var(--tx), var(--ty))
        rotate(var(--r))
        scale(var(--s));
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .shatter-tile {
      animation: none;
      opacity: 0;
    }
  }
</style>

<script>
  // =============================================================
  // FORM BEHAVIOR — POST JSON to Zapier, show status, prevent mailto
  // =============================================================
  const form = document.querySelector<HTMLFormElement>('[data-connect-form]');
  const statusEl = document.querySelector<HTMLParagraphElement>('[data-form-status]');
  const submitBtn = document.querySelector<HTMLButtonElement>('[data-submit]');

  if (form && statusEl && submitBtn) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      // Honeypot — silently bail if a bot filled the hidden field
      const formData = new FormData(form);
      if (formData.get('website')) {
        statusEl.setAttribute('data-state', 'success');
        statusEl.textContent = 'Thanks — your message was received.';
        form.reset();
        return;
      }

      // Minimal client-side validation for required fields
      const name = (formData.get('name') ?? '').toString().trim();
      const email = (formData.get('email') ?? '').toString().trim();
      const message = (formData.get('message') ?? '').toString().trim();

      if (!name || !email || !message) {
        statusEl.setAttribute('data-state', 'error');
        statusEl.textContent = 'Please fill in name, email, and message before sending.';
        return;
      }

      const webhook = form.getAttribute('data-webhook');
      if (!webhook) {
        statusEl.setAttribute('data-state', 'error');
        statusEl.textContent = 'Form misconfigured — webhook missing. Please email us directly.';
        return;
      }

      // Build URL-encoded payload for Zapier.
      // x-www-form-urlencoded is a "simple request" — no CORS preflight, so
      // Zapier accepts it directly from the browser. Zapier parses the fields
      // exactly the same way it would parse JSON.
      const payload = new URLSearchParams();
      payload.append('source', 'huntsville3pl.com/connect');
      payload.append('submitted_at', new Date().toISOString());
      formData.forEach((value, key) => {
        if (key !== 'website') payload.append(key, value.toString());
      });

      submitBtn.setAttribute('data-pending', 'true');
      statusEl.removeAttribute('data-state');
      statusEl.textContent = 'Sending…';

      try {
        const res = await fetch(webhook, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: payload.toString(),
        });

        if (!res.ok) throw new Error(`HTTP ${res.status}`);

        // Success → trigger the shatter animation and confirmation card.
        // Status text is set as a fallback for screen readers / no-anim users.
        statusEl.setAttribute('data-state', 'success');
        statusEl.textContent = 'Your message has been sent.';
        triggerShatter();
      } catch (err) {
        statusEl.setAttribute('data-state', 'error');
        statusEl.textContent = "We couldn't send that just now. Please try again, or email us at info@sams3plsolutions.com.";
        console.error('[connect-form]', err);
      } finally {
        submitBtn.removeAttribute('data-pending');
      }
    });
  }

  // =============================================================
  // SHATTER + CONFIRMATION
  // -------------------------------------------------------------
  // Called from the submit handler on a successful Zapier response.
  // Builds a grid of black tiles over the Send button, animates them
  // outward, fades the form, and reveals the centered confirm card.
  // =============================================================
  const shatterStage = document.querySelector<HTMLDivElement>('[data-shatter-stage]');
  const formFade = document.querySelector<HTMLDivElement>('[data-form-fade]');
  const confirmCard = document.querySelector<HTMLDivElement>('[data-confirm-card]');
  const confirmClose = document.querySelector<HTMLButtonElement>('[data-confirm-close]');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function showConfirmCard() {
    if (!confirmCard) return;
    confirmCard.hidden = false;
    // Force layout so the transition runs, then activate.
    requestAnimationFrame(() => {
      confirmCard.setAttribute('data-active', 'true');
      // Move focus to the close button for accessibility.
      const close = confirmCard.querySelector<HTMLButtonElement>('[data-confirm-close]');
      close?.focus();
    });
  }

  function triggerShatter() {
    if (!submitBtn || !shatterStage) {
      showConfirmCard();
      return;
    }

    if (prefersReducedMotion) {
      // Skip the spectacle for motion-sensitive users.
      submitBtn.style.visibility = 'hidden';
      formFade?.setAttribute('data-active', 'true');
      showConfirmCard();
      return;
    }

    const rect = submitBtn.getBoundingClientRect();
    const TILE = 12;
    const cols = Math.max(1, Math.ceil(rect.width / TILE));
    const rows = Math.max(1, Math.ceil(rect.height / TILE));
    const cx = rect.width / 2;
    const cy = rect.height / 2;
    // Diagonal of the viewport — used as a max travel distance so
    // tiles can fly fully off-screen on any device.
    const maxDist = Math.hypot(window.innerWidth, window.innerHeight);

    // Position the stage exactly over the button (viewport-fixed).
    shatterStage.style.top = `${rect.top}px`;
    shatterStage.style.left = `${rect.left}px`;
    shatterStage.style.width = `${rect.width}px`;
    shatterStage.style.height = `${rect.height}px`;
    shatterStage.innerHTML = '';

    // Hide the button (visibility, not display — preserves layout).
    submitBtn.style.visibility = 'hidden';

    // Build tiles. DocumentFragment keeps the DOM write to a single
    // reflow even with hundreds of tiles.
    const frag = document.createDocumentFragment();
    for (let row = 0; row < rows; row++) {
      for (let col = 0; col < cols; col++) {
        const tile = document.createElement('div');
        tile.className = 'shatter-tile';
        const px = col * TILE;
        const py = row * TILE;
        tile.style.left = `${px}px`;
        tile.style.top = `${py}px`;

        // Direction: vector pointing OUTWARD from the button center.
        // Each tile flies away from where it was sitting — gives the
        // explosion physical coherence (true outward burst, not noise).
        const dx = px + TILE / 2 - cx;
        const dy = py + TILE / 2 - cy;
        const len = Math.hypot(dx, dy) || 1;
        const dirX = dx / len;
        const dirY = dy / len;

        // Distance: huge — tiles really fly off-screen. Edge tiles go
        // farthest, center tiles get a generous minimum so nothing
        // looks anchored.
        const dist = 320 + Math.random() * (maxDist * 0.55);

        // Add some random angular jitter so it doesn't look mechanical.
        const jitterAngle = (Math.random() - 0.5) * 0.9; // ±0.45 rad
        const cosJ = Math.cos(jitterAngle);
        const sinJ = Math.sin(jitterAngle);
        const jx = dirX * cosJ - dirY * sinJ;
        const jy = dirX * sinJ + dirY * cosJ;

        const tx = jx * dist;
        // Upward bias — shatter feels gravity-defying, not just outward.
        const ty = jy * dist - 220 - Math.random() * 120;

        // Wild tumble: ±2.5 rotations
        const rot = (Math.random() - 0.5) * 1800;
        // Slight scale variance — some tiles look thrown harder
        const scl = 0.7 + Math.random() * 1.1;
        // Stagger so the explosion isn't a single instant
        const delay = Math.random() * 240;

        tile.style.setProperty('--tx', `${tx}px`);
        tile.style.setProperty('--ty', `${ty}px`);
        tile.style.setProperty('--r', `${rot}deg`);
        tile.style.setProperty('--s', `${scl}`);
        tile.style.animationDelay = `${delay}ms`;

        frag.appendChild(tile);
      }
    }
    shatterStage.appendChild(frag);

    // Fade the form to off-white partway through the shatter.
    setTimeout(() => formFade?.setAttribute('data-active', 'true'), 700);

    // Reveal the confirmation card after the shatter mostly completes.
    setTimeout(showConfirmCard, 1250);

    // Cleanup the tile DOM once they're invisible / off-screen.
    setTimeout(() => {
      if (shatterStage) shatterStage.innerHTML = '';
    }, 1800);
  }

  // Close button → navigate to homepage.
  confirmClose?.addEventListener('click', () => {
    window.location.href = '/';
  });

  // Allow ESC to close as well (also returns to homepage, per the
  // close button's stated behavior — there's no other dismiss path).
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && confirmCard && !confirmCard.hidden) {
      window.location.href = '/';
    }
  });
</script>
