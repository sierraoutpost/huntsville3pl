---
// Differentiators.astro — NEOBRUTALIST six differentiators
// Bold numbering, industrial card treatment, asymmetric stagger

import { city } from '@data/city';
import { brand } from '@data/brand';

const differentiators = [
  {
    number: '01',
    title: 'Strategic Location',
    description: `At the convergence of I-65 and I-565 — one-day truck reach to Nashville, Atlanta, Memphis, Birmingham, Louisville, and beyond.`,
  },
  {
    number: '02',
    title: 'Port & Infrastructure',
    description: `The Port of ${city.name} combines air cargo (#21 in the U.S.), rail intermodal (33,745 lifts in 2024), and highway freight — $300M+ invested.`,
  },
  {
    number: '03',
    title: 'FTZ Readiness',
    description: `Positioned to facilitate Foreign Trade Zone benefits through the Port of ${city.name}'s International Intermodal Center — an inland port of entry for international cargo.`,
  },
  {
    number: '04',
    title: 'White Glove Standards',
    description: `In a city where precision puts rockets in orbit, we hold our logistics to the same standard. Every shipment handled with accuracy and care.`,
  },
  {
    number: '05',
    title: 'National Network',
    description: `${city.name} is one of ${brand.network.length} Sams 3PL Solutions locations nationwide. Your freight has options — and a team behind every one of them.`,
  },
  {
    number: '06',
    title: 'No Surprises',
    description: `Real-time WMS visibility, dedicated account management, and proactive communication. You'll know where your inventory is before you ask.`,
  },
];
---

<section class="diff-section section" aria-labelledby="diff-heading">
  <div class="container">
    <div class="diff-header">
      <p class="diff-eyebrow">Why Choose Us</p>
      <h2 class="diff-heading" id="diff-heading">
        Six reasons. Zero&nbsp;guesswork.
      </h2>
    </div>

    <div class="diff-grid">
      {differentiators.map((d, i) => (
        <div class:list={['diff-card', { 'diff-card--accent': i === 1 || i === 4 }]}>
          <span class="diff-number">{d.number}</span>
          <h3 class="diff-title">{d.title}</h3>
          <p class="diff-desc">{d.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .diff-section {
    background-color: var(--color-off-white);
    border-top: 3px solid var(--color-black);
  }

  .diff-header {
    margin-bottom: var(--space-8);
  }

  .diff-eyebrow {
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-brick-red);
    margin-bottom: var(--space-3);
  }

  .diff-heading {
    font-size: var(--fs-3xl);
    line-height: 1;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-black);
  }

  /* ---- Grid — 2-col then 3-col ---- */
  .diff-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .diff-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .diff-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ---- Card — thick border, hard shadow ---- */
  .diff-card {
    padding: var(--space-5);
    border: 3px solid var(--color-black);
    box-shadow: 5px 5px 0 var(--color-black);
    background: var(--color-off-white);
    transition:
      transform 80ms ease,
      box-shadow 80ms ease;
  }

  .diff-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 8px 8px 0 var(--color-black);
  }

  /* Accent cards — yellow background */
  .diff-card--accent {
    background: var(--color-electric-yellow);
  }

  .diff-number {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-3xl);
    font-weight: 700;
    color: var(--color-brick-red);
    line-height: 1;
    margin-bottom: var(--space-3);
    letter-spacing: -0.02em;
  }

  .diff-card--accent .diff-number {
    color: var(--color-black);
  }

  .diff-title {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-black);
    margin-bottom: var(--space-3);
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .diff-desc {
    font-size: var(--fs-base);
    line-height: 1.5;
    color: var(--color-black);
    opacity: 0.8;
    max-width: none;
  }

  .diff-card--accent .diff-desc {
    opacity: 0.9;
  }
</style>
