---
// BrandBanner.astro — Massive "HUNTSVILLE 3PL" banner (Row 1)
// White background, black text, 3PL in Brick Red
// "A SAMS 3PL SOLUTIONS COMPANY" aligned under the H
---

<div class="brand-banner">
  <div class="brand-block">
    <a href="/" class="brand-banner-link" aria-label="Huntsville 3PL — Home">
      <span class="brand-name">Huntsville<span class="brand-3pl">3PL</span></span>
    </a>
    <span class="brand-sub">A Sams 3PL Solutions Company</span>
  </div>
</div>

<style>
  .brand-banner {
    background: white;
    padding: var(--space-3) 1.25rem var(--space-2);
    display: flex;
    justify-content: center;
  }

  /* This block wraps both name + subtitle so subtitle left-aligns with H */
  .brand-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .brand-banner-link {
    text-decoration: none;
    display: block;
  }

  .brand-name {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(4rem, 13vw, 11rem);
    font-weight: 700;
    color: var(--color-black);
    line-height: 0.85;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }

  .brand-3pl {
    color: var(--color-brick-red);
    margin-left: 0.05em;
  }

  .brand-sub {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--color-black);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: var(--space-1);
    /* Fine-tune: nudge right to exact-align with H */
    padding-left: 0.15em;
  }
</style>
