---
// BrandBanner.astro — Massive "HUNTSVILLE 3PL" banner (Row 1)
// White background, black text, 3PL in Brick Red
// "A SAMS 3PL SOLUTIONS COMPANY" positioned under "HUNT"
---

<div class="brand-banner">
  <a href="/" class="brand-banner-link" aria-label="Huntsville 3PL — Home">
    <span class="brand-name">Huntsville<span class="brand-3pl">3PL</span></span>
  </a>
  <span class="brand-sub">A Sams 3PL Solutions Company</span>
</div>

<style>
  .brand-banner {
    background: white;
    text-align: center;
    padding: var(--space-4) 1.25rem;
    position: relative;
  }

  .brand-banner-link {
    text-decoration: none;
    display: block;
  }

  .brand-name {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(4rem, 13vw, 11rem);
    font-weight: 700;
    color: var(--color-black);
    line-height: 0.85;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }

  .brand-3pl {
    color: var(--color-brick-red);
    margin-left: 0.05em;
  }

  .brand-sub {
    display: block;
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--color-black);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: var(--space-2);
    text-align: left;
    padding-left: clamp(0.5rem, 2vw, 2rem);
  }
</style>
