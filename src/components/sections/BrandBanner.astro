---
// BrandBanner.astro — Massive "HUNTSVILLE 3PL" banner (Row 1)
// White background, black text, 3PL in Brick Red
// "A SAMS 3PL SOLUTIONS COMPANY" aligned under the H
---

<div class="brand-banner">
  <div class="brand-sub-group">
    <span class="brand-sub">A Sams 3PL Solutions</span>
    <span class="brand-sub brand-sub--right">Company</span>
  </div>
  <div class="brand-block">
    <a href="/" class="brand-banner-link" aria-label="Huntsville 3PL — Home">
      <span class="brand-name">Huntsville<span class="brand-3pl">3PL</span></span>
    </a>
  </div>
</div>

<style>
  .brand-banner {
    background: white;
    padding: var(--space-3) 1.25rem var(--space-2);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    position: relative;
    overflow: hidden;
    /* Guarantee enough vertical room for the rotated sub-text so it never
       gets clipped by overflow:hidden. Scales with viewport. */
    min-height: clamp(6.5rem, 11.5vw, 10rem);
  }

  /* On desktop, right-align wordmark so trailing "L" meets phone/CTA divider.
     Right padding clears the Connect CTA column. Stepped down at mid widths
     so the wordmark has room and can't overflow the viewport. */
  @media (min-width: 1024px) {
    .brand-banner {
      justify-content: flex-end;
      padding-right: 7rem;
    }
  }
  @media (min-width: 1280px) {
    .brand-banner {
      padding-right: 9.5rem;
    }
  }
  @media (min-width: 1536px) {
    .brand-banner {
      padding-right: 11.5rem;
    }
  }

  .brand-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .brand-banner-link {
    text-decoration: none;
    display: block;
  }

  .brand-name {
    display: block;
    font-family: var(--font-display);
    /* Fluid across every breakpoint. Ceiling tuned so 13-char "HUNTSVILLE3PL"
       always fits inside the banner row after accounting for CTA-column
       padding on desktop. */
    font-size: clamp(3rem, 11vw, 9rem);
    font-weight: 700;
    color: var(--color-black);
    line-height: 0.85;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .brand-3pl {
    color: var(--color-brick-red);
    margin-left: 0.05em;
  }

  .brand-sub-group {
    position: absolute;
    left: 1.25rem;
    bottom: 0.5rem;
    top: 0.5rem;
    display: flex;
    flex-direction: row;
    gap: 0.35rem;
  }

  .brand-sub {
    font-family: var(--font-body);
    /* Fluid sub-text — shrinks with viewport so its rotated length always
       fits within the banner's vertical space across all screen sizes. */
    font-size: clamp(0.55rem, 0.85vw, 0.8rem);
    font-weight: 500;
    color: var(--color-black);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    transform-origin: center center;
  }

  /* Hide vertical subtitle on small screens where it crowds the logo.
     Bumped to 900px so narrow tablets/laptops don't show a clipped
     sub-group — it only appears once the banner is tall enough. */
  @media (max-width: 899px) {
    .brand-sub-group {
      display: none;
    }
  }
</style>
