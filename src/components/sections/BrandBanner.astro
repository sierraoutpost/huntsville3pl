---
// BrandBanner.astro — Massive "HUNTSVILLE 3PL" banner (Row 1)
// White background, black text, 3PL in Brick Red
// "A SAMS 3PL SOLUTIONS COMPANY" aligned under the H
---

<div class="brand-banner">
  <span class="brand-sub">A Sams 3PL Solutions Company</span>
  <div class="brand-block">
    <a href="/" class="brand-banner-link" aria-label="Huntsville 3PL — Home">
      <span class="brand-name">Huntsville<span class="brand-3pl">3PL</span></span>
    </a>
  </div>
</div>

<style>
  .brand-banner {
    background: white;
    padding: var(--space-3) 1.25rem var(--space-2);
    display: flex;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .brand-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .brand-banner-link {
    text-decoration: none;
    display: block;
  }

  .brand-name {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(4rem, 13vw, 11rem);
    font-weight: 700;
    color: var(--color-black);
    line-height: 0.85;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }

  .brand-3pl {
    color: var(--color-brick-red);
    margin-left: 0.05em;
  }

  .brand-sub {
    position: absolute;
    left: 1.25rem;
    bottom: 0.5rem;
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    color: var(--color-black);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    transform-origin: center center;
  }

  /* Hide vertical subtitle on small screens where it crowds the logo */
  @media (max-width: 767px) {
    .brand-sub {
      display: none;
    }
  }
</style>
